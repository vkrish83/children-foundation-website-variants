---
import heroImage from '../assets/hero-v5.png';
import volunteerImage from '../assets/volunteer-v5.png';
---

<section id="about" class="relative overflow-hidden bg-[#FAF7F2] px-5 py-16 lg:px-8 lg:py-24">
	<div class="absolute right-0 top-24 hidden h-32 w-1/3 bg-[#DD8A1A] lg:block"></div>
	<div class="mx-auto grid max-w-7xl gap-14 lg:grid-cols-[0.9fr_1.1fr] lg:items-center">
		<div class="relative z-10">
			<p class="mb-5 inline-flex bg-[#111827] px-4 py-2 text-xs font-black uppercase text-white">
				About Children First
			</p>
			<h1 class="text-5xl font-black uppercase leading-[0.98] text-[#111827] sm:text-6xl lg:text-7xl xl:text-[5.25rem]">
				A Community Committed To Every Child.
			</h1>
			<p class="mt-7 max-w-xl text-lg font-medium leading-8 text-[#1F2937]">
				Children First grows around a simple belief: every child deserves people who notice, encourage, teach, listen and keep showing up.
			</p>
		</div>

		<div class="relative min-h-[520px] lg:min-h-[640px]">
			<img
				src={volunteerImage.src}
				alt="Volunteers and children learning together"
				class="absolute right-0 top-0 h-[72%] w-[92%] object-cover shadow-[18px_18px_0_#0F766E]"
			/>
			<img
				src={heroImage.src}
				alt="Children smiling with notebooks outdoors"
				class="absolute bottom-0 left-0 h-[36%] w-[58%] border-[10px] border-[#FAF7F2] object-cover shadow-[-18px_18px_0_#DD8A1A]"
			/>
			<div class="absolute bottom-12 right-2 bg-[#111827] p-6 text-white sm:right-8">
				<p class="text-sm font-black uppercase text-[#DD8A1A]">People first</p>
				<p class="mt-2 max-w-48 text-2xl font-black uppercase leading-none">A movement built face to face.</p>
			</div>
		</div>
	</div>
</section>
