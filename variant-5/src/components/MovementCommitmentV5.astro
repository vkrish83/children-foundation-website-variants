<section class="bg-[#111827] px-5 py-20 text-white lg:px-8 lg:py-28">
	<div class="mx-auto max-w-7xl">
		<p class="mb-8 text-sm font-black uppercase text-[#DD8A1A]">The commitment</p>
		<div class="grid gap-10 lg:grid-cols-[1.25fr_0.75fr] lg:items-end">
