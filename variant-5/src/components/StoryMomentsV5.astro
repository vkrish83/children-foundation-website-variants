---
const moments = [
	{
		number: '01',
		title: 'First Question',
		copy: 'A quiet student asks for help, then asks again with a little more courage.',
		accent: 'bg-[#DD8A1A] text-[#111827]',
	},
	{
		number: '02',
		title: 'First Mentor',
		copy: 'A volunteer learns a name, notices a spark and becomes a steady part of the week.',
		accent: 'bg-[#0F766E] text-white',
	},
	{
		number: '03',
		title: 'First Dream',
		copy: 'A child says the future out loud and the room starts building around it.',
		accent: 'bg-white text-[#111827]',
	},
];
---

<section class="bg-[#111827] px-5 py-20 text-white lg:px-8 lg:py-28">
	<div class="mx-auto max-w-7xl">
		<div class="mb-12 grid gap-6 lg:grid-cols-[0.7fr_1.3fr] lg:items-end">
			<p class="text-sm font-black uppercase text-[#DD8A1A]">Movement moments</p>
			<h2 class="max-w-5xl text-4xl font-black uppercase leading-none sm:text-6xl">
				Stories are not endings. They are starts.
			</h2>
		</div>

		<div class="grid gap-5 md:grid-cols-3">
			{moments.map((moment, index) => (
				<article class={`min-h-80 p-7 ${moment.accent} ${index === 1 ? 'md:mt-14' : ''} ${index === 2 ? 'md:mt-28' : ''}`}>
					<p class="text-6xl font-black uppercase leading-none">{moment.number}</p>
					<h3 class="mt-10 text-4xl font-black uppercase leading-none">{moment.title}</h3>
					<p class="mt-5 text-base font-bold leading-7 opacity-80">{moment.copy}</p>
				</article>
			))}
		</div>
	</div>
</section>
