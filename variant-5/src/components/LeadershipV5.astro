---
import founderOne from '../assets/founder-1.png';
import founderTwo from '../assets/founder-2.png';
import founderThree from '../assets/founder-3.png';

const leaders = [
	{
		name: 'Aravind Kumar',
		role: 'Founder, Community Learning',
		text: 'Arun began Children First by gathering neighbors around weekend learning circles and a promise to stay close to the children they serve.',
		image: founderOne,
		classes: 'lg:translate-y-10',
	},
	{
		name: 'Suresh Narayanan',
		role: 'Founder, Volunteer Action',
		text: 'Dev builds local volunteer teams that make participation simple, consistent and rooted in trust.',
		image: founderTwo,
		classes: '',
	},
	{
		name: 'Karthik Raman',
		role: 'Founder, Mentorship',
		text: 'Ravi helps shape mentorship pathways where children meet adults who listen carefully and expect great things from them.',
		image: founderThree,
		classes: 'lg:translate-y-16',
	},
];
---

<section class="bg-white px-5 py-20 lg:px-8 lg:py-28">
	<div class="mx-auto max-w-7xl">
		<div class="mb-14 flex flex-col gap-6 lg:flex-row lg:items-end lg:justify-between">
			<div>
				<p class="mb-5 text-sm font-black uppercase text-[#DD8A1A]">Leadership</p>
				<h2 class="max-w-3xl text-4xl font-black uppercase leading-none text-[#111827] sm:text-6xl">
					Founded by people who believe proximity changes everything.
				</h2>
			</div>
			<p class="max-w-md text-lg font-medium leading-8 text-[#1F2937]">
				The work is led by people who spend time in classrooms, in communities and beside the children at the heart of the movement.
			</p>
		</div>

		<div class="grid gap-6 lg:grid-cols-3">
			{leaders.map((leader) => (
				<article class={`relative bg-[#FAF7F2] ${leader.classes}`}>
					<img src={leader.image.src} alt={leader.name} class="h-[380px] w-full object-cover" />
					<div class="p-6">
						<p class="text-sm font-black uppercase text-[#0F766E]">{leader.role}</p>
						<h3 class="mt-2 text-3xl font-black uppercase text-[#111827]">{leader.name}</h3>
						<p class="mt-4 text-base font-medium leading-7 text-[#1F2937]">{leader.text}</p>
					</div>
				</article>
			))}
		</div>
	</div>
</section>
