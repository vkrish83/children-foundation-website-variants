---
import founderOne from '../assets/founder-1.png';
import founderTwo from '../assets/founder-2.png';
import founderThree from '../assets/founder-3.png';

const builders = [
	{
		name: 'Aravind Kumar',
		role: 'Community Learning',
		text: 'Gathers people around learning spaces where children are known by name and encouraged with care.',
		image: founderOne,
		classes: 'lg:translate-y-12',
	},
	{
		name: 'Suresh Narayanan',
		role: 'Volunteer Action',
		text: 'Builds simple pathways for neighbors and mentors to participate consistently and usefully.',
		image: founderTwo,
		classes: '',
	},
	{
		name: 'Karthik Raman',
		role: 'Mentorship',
		text: 'Shapes listening-led mentorship that helps children find confidence beyond one lesson.',
		image: founderThree,
		classes: 'lg:translate-y-20',
	},
];
---

<section class="bg-white px-5 py-20 lg:px-8 lg:py-28">
	<div class="mx-auto max-w-7xl">
		<div class="mb-14 flex flex-col gap-6 lg:flex-row lg:items-end lg:justify-between">
			<div>
				<p class="mb-5 text-sm font-black uppercase text-[#DD8A1A]">Leadership circle</p>
				<h2 class="max-w-4xl text-4xl font-black uppercase leading-none text-[#111827] sm:text-6xl">
					Not executive distance. Community builders in motion.
				</h2>
			</div>
			<p class="max-w-md text-lg font-medium leading-8 text-[#1F2937]">
				Each founder carries a different part of the movement, but the posture is shared: stay close, act with people and keep showing up.
			</p>
		</div>

		<div class="grid gap-6 lg:grid-cols-3">
			{builders.map((builder) => (
				<article class={`relative bg-[#FAF7F2] ${builder.classes}`}>
					<img src={builder.image.src} alt={builder.name} class="h-[390px] w-full object-cover" />
					<div class="p-6">
						<p class="text-sm font-black uppercase text-[#0F766E]">{builder.role}</p>
						<h3 class="mt-2 text-3xl font-black uppercase leading-none text-[#111827]">{builder.name}</h3>
						<p class="mt-4 text-base font-medium leading-7 text-[#1F2937]">{builder.text}</p>
					</div>
				</article>
			))}
		</div>
	</div>
</section>
