---
const links = [
	{ label: 'About', href: '/about' },
	{ label: 'Founders', href: '/founders' },
	{ label: 'Programs', href: '/programs' },
	{ label: 'Stories', href: '/stories' },
	{ label: 'Volunteer', href: '/volunteer' },
	{ label: 'Contact', href: '/contact' },
];
---

<footer class="bg-[#111827] px-5 py-12 text-white lg:px-8">
	<div class="mx-auto grid max-w-7xl gap-10 md:grid-cols-[1fr_auto] md:items-start">
		<div>
			<a href="/" class="inline-flex items-center gap-3">
				<span class="flex h-11 w-11 items-center justify-center bg-[#DD8A1A] text-xl font-black text-[#111827]">CF</span>
				<span>
					<span class="block text-lg font-black uppercase">Children First</span>
					<span class="block text-xs font-bold uppercase text-[#DD8A1A]">Community Movement</span>
				</span>
			</a>
			<p class="mt-5 max-w-lg text-sm font-semibold leading-7 text-white/70">
				Education, mentorship and community support that helps children move forward with confidence.
			</p>
		</div>

		<div class="flex flex-wrap gap-4 md:justify-end">
			{links.map((item) => (
				<a href={item.href} class="text-sm font-black uppercase text-white/80 transition hover:text-[#DD8A1A]">{item.label}</a>
			))}
		</div>
	</div>
	<div class="mx-auto mt-10 flex max-w-7xl flex-col gap-3 border-t border-white/10 pt-6 text-xs font-bold uppercase text-white/50 sm:flex-row sm:items-center sm:justify-between">
		<p>&copy; 2026 Children First Foundation</p>
		<p>Community-powered futures</p>
	</div>
</footer>
