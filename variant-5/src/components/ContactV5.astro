---
const actions = [
	{
		title: 'Volunteer With Us',
		text: 'Bring your time into a classroom, mentoring circle or weekend learning session.',
		href: '/volunteer',
		label: 'Become A Volunteer',
	},
	{
		title: 'Partner With Us',
		text: 'Build community-led support with your school, workplace, group or local network.',
		href: '/programs',
		label: 'Explore Programs',
	},
	{
		title: 'Share A Story',
		text: 'Tell us about a child, family or community moment that should move forward.',
		href: '/stories',
		label: 'See Stories',
	},
];
---

<section class="bg-[#FAF7F2] px-5 py-16 lg:px-8 lg:py-24">
	<div class="mx-auto max-w-7xl">
		<div class="grid gap-10 lg:grid-cols-[0.82fr_1.18fr] lg:items-end">
			<div>
				<p class="mb-5 inline-flex bg-[#111827] px-4 py-2 text-xs font-black uppercase text-white">
					Contact
				</p>
				<h1 class="text-5xl font-black uppercase leading-[0.95] text-[#111827] sm:text-6xl lg:text-7xl">
					Ready To Build With Us?
				</h1>
			</div>
			<p class="max-w-2xl text-lg font-semibold leading-8 text-[#1F2937]">
				Start with a conversation. Whether you want to volunteer, partner, support a child or bring a learning circle to your community, this is the next step.
			</p>
		</div>

		<div class="mt-14 grid gap-5 lg:grid-cols-3">
			{actions.map((action, index) => (
				<article class={`border-2 border-[#111827] p-7 ${index === 1 ? 'bg-[#111827] text-white shadow-[10px_10px_0_#DD8A1A]' : 'bg-white shadow-[10px_10px_0_#0F766E]'}`}>
					<p class={`text-sm font-black uppercase ${index === 1 ? 'text-[#DD8A1A]' : 'text-[#0F766E]'}`}>0{index + 1}</p>
					<h2 class="mt-8 text-3xl font-black uppercase leading-none">{action.title}</h2>
					<p class={`mt-5 text-base font-bold leading-7 ${index === 1 ? 'text-white/75' : 'text-[#1F2937]'}`}>{action.text}</p>
					<a href={action.href} class={`mt-8 inline-flex px-5 py-4 text-sm font-black uppercase transition ${index === 1 ? 'bg-[#DD8A1A] text-[#111827] hover:bg-white' : 'bg-[#111827] text-white hover:bg-[#DD8A1A] hover:text-[#111827]'}`}>
						{action.label}
					</a>
				</article>
			))}
		</div>

		<div class="mt-14 grid gap-6 bg-[#DD8A1A] p-8 text-[#111827] md:grid-cols-[1fr_auto] md:items-center lg:p-10">
			<div>
				<p class="text-sm font-black uppercase">Movement desk</p>
				<p class="mt-2 text-3xl font-black uppercase leading-none">hello@childrenfirst.org</p>
			</div>
			<a href="mailto:hello@childrenfirst.org" class="bg-[#111827] px-7 py-4 text-center text-sm font-black uppercase text-white transition hover:bg-[#0F766E]">
				Email Us
			</a>
		</div>
	</div>
</section>
