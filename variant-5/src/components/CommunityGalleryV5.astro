---
import heroImage from '../assets/hero-v5.png';
import programsImage from '../assets/programs.png';
import storyImage from '../assets/story-girl.png';
import volunteerImage from '../assets/volunteer-v5.png';
import dreamImage from '../assets/dream.png';
---

<section id="gallery" class="overflow-hidden bg-[#111827] px-5 py-20 text-white lg:px-8 lg:py-28">
	<div class="mx-auto max-w-7xl">
		<div class="mb-12 grid gap-6 lg:grid-cols-[0.75fr_1.25fr] lg:items-end">
			<p class="text-sm font-black uppercase text-[#DD8A1A]">Community gallery</p>
			<h2 class="text-4xl font-black uppercase leading-none sm:text-6xl">
				The movement is made of faces, classrooms, hands and shared momentum.
			</h2>
		</div>

		<div class="grid auto-rows-[145px] grid-cols-2 gap-4 md:grid-cols-8 md:auto-rows-[120px] lg:auto-rows-[135px]">
			<img src={programsImage.src} alt="Volunteer surrounded by smiling children" class="col-span-2 row-span-3 h-full w-full object-cover md:col-span-5 md:row-span-4" />
			<img src={storyImage.src} alt="Schoolgirl smiling with books" class="row-span-2 h-full w-full object-cover md:col-span-3 md:row-span-2" />
			<div class="flex h-full items-center bg-[#DD8A1A] p-5 text-[#111827] md:col-span-2 md:row-span-1">
				<p class="text-3xl font-black uppercase leading-none">Join In</p>
			</div>
			<img src={heroImage.src} alt="Children sitting outdoors with notebooks" class="h-full w-full object-cover md:col-span-1 md:row-span-1" />
			<img src={volunteerImage.src} alt="Volunteers helping children with school work" class="col-span-2 row-span-2 h-full w-full object-cover md:col-span-3 md:row-span-3 md:col-start-6" />
			<img src={dreamImage.src} alt="Children learning in a classroom" class="col-span-2 row-span-2 h-full w-full object-cover md:col-span-5 md:row-span-2" />
		</div>
	</div>
</section>
