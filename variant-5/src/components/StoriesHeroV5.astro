---
import heroImage from '../assets/hero-v5.png';
import storyImage from '../assets/story-girl.png';
import volunteerImage from '../assets/volunteer-v5.png';
---

<section class="relative overflow-hidden bg-[#111827] px-5 py-16 text-white lg:px-8 lg:py-24">
	<div class="absolute left-0 top-24 hidden h-28 w-2/5 bg-[#DD8A1A] lg:block"></div>

	<div class="mx-auto grid max-w-7xl gap-16 lg:grid-cols-[1.05fr_0.95fr] lg:items-center lg:gap-20">
		<div class="relative z-10 lg:py-10">
			<p class="mb-7 inline-flex bg-[#DD8A1A] px-4 py-2 text-xs font-black uppercase text-[#111827]">
				Stories in motion
			</p>
			<h1 class="max-w-5xl text-5xl font-black uppercase leading-[0.92] text-white sm:text-6xl lg:text-7xl xl:text-8xl">
				Stories That Move
				<span class="text-[#DD8A1A]">The Movement Forward.</span>
			</h1>
			<p class="mt-7 max-w-xl text-lg font-semibold leading-8 text-white/75">
				Every raised hand, shared notebook and steady volunteer becomes proof that community can change the pace of a child's life.
			</p>
			<div class="mt-9 flex flex-wrap gap-3">
				<a href="#featured-story" class="bg-white px-7 py-4 text-sm font-black uppercase text-[#111827] transition hover:bg-[#DD8A1A]">
					Read The Feature
				</a>
				<a href="#voices" class="border-2 border-white px-7 py-4 text-sm font-black uppercase text-white transition hover:border-[#DD8A1A] hover:text-[#DD8A1A]">
					Hear The Voices
				</a>
			</div>
		</div>

		<div class="relative min-h-[500px] sm:min-h-[580px] lg:min-h-[620px]">
			<img
				src={heroImage.src}
				alt="Children smiling together with notebooks outdoors"
				class="absolute right-0 top-8 h-[44%] w-[86%] object-cover shadow-[16px_16px_0_#DD8A1A] sm:h-[46%]"
			/>
			<img
				src={storyImage.src}
				alt="A smiling schoolgirl holding notebooks outside school"
				class="absolute bottom-6 left-0 h-[43%] w-[56%] border-[10px] border-[#111827] object-cover shadow-[-14px_14px_0_#0F766E] sm:w-[48%]"
			/>
			<img
				src={volunteerImage.src}
				alt="Volunteers helping children write during a study session"
				class="absolute bottom-24 right-0 h-[26%] w-[48%] border-[10px] border-[#111827] object-cover sm:bottom-28"
			/>
		</div>
	</div>
</section>
