---
import dreamImage from '../assets/dream.png';
---

<section id="education" class="bg-[#111827] px-5 py-20 text-white lg:px-8 lg:py-28">
	<div class="mx-auto grid max-w-7xl gap-12 lg:grid-cols-[1.08fr_0.92fr] lg:items-center">
		<div class="relative">
			<div class="absolute -left-5 -top-5 h-28 w-28 bg-[#DD8A1A]"></div>
			<img src={dreamImage.src} alt="Children learning in a classroom with a teacher" class="relative h-[560px] w-full object-cover" />
		</div>

		<div class="lg:pl-10">
			<p class="mb-5 text-sm font-black uppercase text-[#DD8A1A]">Education program</p>
			<h2 class="text-4xl font-black uppercase leading-none sm:text-6xl">
				Learning support that turns a classroom into a circle of confidence.
			</h2>
			<p class="mt-7 text-lg font-medium leading-8 text-white/80">
				Children receive steady study support, reading practice and patient guidance from adults who make learning feel possible. The story is not a scorecard; it is the first time a child reads aloud, asks for help or helps someone else understand.
			</p>
			<div class="mt-8 border-l-4 border-[#DD8A1A] pl-5">
				<p class="text-2xl font-black uppercase text-white">A child who once stayed quiet starts raising a hand.</p>
			</div>
		</div>
	</div>
</section>
