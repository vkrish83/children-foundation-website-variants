---
const values = [
	{
		title: 'Belonging',
		text: 'Every child should feel known before they are asked to perform.',
		classes: 'bg-[#DD8A1A] text-[#111827] lg:col-span-5',
	},
	{
		title: 'Opportunity',
		text: 'Access grows when communities open doors together.',
		classes: 'bg-[#FAF7F2] text-[#111827] lg:col-span-3',
	},
	{
		title: 'Participation',
		text: 'A movement is built by many people taking one useful step.',
		classes: 'bg-[#0F766E] text-white lg:col-span-4',
	},
	{
		title: 'Hope',
		text: 'Hope becomes real when a child can see the next path and the people walking with them.',
		classes: 'bg-white text-[#111827] lg:col-span-7',
	},
];
---

<section class="bg-[#111827] px-5 py-20 lg:px-8 lg:py-28">
	<div class="mx-auto max-w-7xl">
		<div class="mb-12 grid gap-6 text-white lg:grid-cols-[1fr_1fr] lg:items-end">
			<h2 class="text-4xl font-black uppercase leading-none sm:text-6xl">
				The values that keep the movement human.
			</h2>
			<p class="max-w-xl text-lg font-semibold leading-8 text-white/75">
				These values shape how we teach, mentor, gather volunteers and make children feel held by something bigger than a program.
			</p>
		</div>

		<div class="grid gap-4 lg:grid-cols-12">
			{values.map((value) => (
				<div class={`min-h-64 p-7 ${value.classes}`}>
					<h3 class="text-4xl font-black uppercase leading-none">{value.title}</h3>
					<p class="mt-6 max-w-md text-lg font-bold leading-8 opacity-80">{value.text}</p>
				</div>
			))}
		</div>
	</div>
</section>
