<section class="bg-white py-20">
  <div class="max-w-5xl mx-auto px-6">
    <div class="grid gap-12 md:grid-cols-2">
      <div>
        <h2 class="text-4xl md:text-5xl font-bold text-[#2F3A45] leading-tight">
          We'd Love To Hear From You
        </h2>

        <p class="mt-8 text-lg text-gray-600 leading-relaxed">
          Share a question, partnership idea or note about how you would like to get involved. Our team will get back to you soon.
        </p>
      </div>

      <form class="space-y-5">
        <div>
          <label for="name" class="block mb-2 font-medium text-[#2F3A45]">
            Name
          </label>
          <input
            id="name"
            type="text"
            name="name"
            placeholder="Name"
            class="w-full border border-gray-200 rounded-xl px-5 py-4 text-[#2F3A45] outline-none focus:border-[#5D9C59]"
          />
        </div>

        <div>
          <label for="email" class="block mb-2 font-medium text-[#2F3A45]">
            Email
          </label>
          <input
            id="email"
            type="email"
            name="email"
            placeholder="Email"
            class="w-full border border-gray-200 rounded-xl px-5 py-4 text-[#2F3A45] outline-none focus:border-[#5D9C59]"
          />
        </div>

        <div>
          <label for="message" class="block mb-2 font-medium text-[#2F3A45]">
            Message
          </label>
          <textarea
            id="message"
            name="message"
            rows="6"
            placeholder="Message"
            class="w-full border border-gray-200 rounded-xl px-5 py-4 text-[#2F3A45] outline-none focus:border-[#5D9C59]"
          ></textarea>
        </div>

        <button
          type="submit"
          class="bg-[#5D9C59] text-white px-8 py-4 rounded-full font-medium transition-all duration-300 hover:scale-105"
        >
          Submit
        </button>
      </form>
    </div>
  </div>
</section>
