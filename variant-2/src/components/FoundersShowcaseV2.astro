---
import founder1 from "../assets/founder-1.png";
import founder2 from "../assets/founder-2.png";
import founder3 from "../assets/founder-3.png";
---

<section class="bg-[#FAFAF8] py-20">

  <div class="max-w-7xl mx-auto px-6">

    <div class="mb-16">

      <p class="uppercase tracking-widest text-[#5D9C59] font-semibold mb-4">
        Meet The Founders
      </p>

      <h2 class="text-5xl font-bold text-[#2F3A45]">
        The People Behind The Mission
      </h2>

    </div>

    <div class="grid md:grid-cols-3 gap-10">

      <!-- Founder 1 -->

      <div>

        <img
          src={founder1.src}
          alt="Founder 1"
          class="w-full aspect-[4/5] object-cover rounded-3xl mb-6"
        />

        <h3 class="text-2xl font-bold text-[#2F3A45]">
          Aravind Kumar
        </h3>

        <p class="text-[#5D9C59] font-medium mt-2">
          Co-Founder
        </p>

        <p class="text-gray-600 mt-4 leading-relaxed">
          Aravind works with school communities across Tamil Nadu to make education support more personal and accessible.
        </p>

      </div>

      <!-- Founder 2 -->

      <div>

        <img
          src={founder2.src}
          alt="Founder 2"
          class="w-full aspect-[4/5] object-cover rounded-3xl mb-6"
        />

        <h3 class="text-2xl font-bold text-[#2F3A45]">
          Suresh Narayanan
        </h3>

        <p class="text-[#5D9C59] font-medium mt-2">
          Co-Founder
        </p>

        <p class="text-gray-600 mt-4 leading-relaxed">
          Suresh focuses on mentorship, family engagement and partnerships that help children stay connected to learning.
        </p>

      </div>

      <!-- Founder 3 -->

      <div>

        <img
          src={founder3.src}
          alt="Founder 3"
          class="w-full aspect-[4/5] object-cover rounded-3xl mb-6"
        />

        <h3 class="text-2xl font-bold text-[#2F3A45]">
          Karthik Raman
        </h3>

        <p class="text-[#5D9C59] font-medium mt-2">
          Co-Founder
        </p>

        <p class="text-gray-600 mt-4 leading-relaxed">
          Karthik develops child-centered programs that build confidence, curiosity and opportunity through steady guidance.
        </p>

      </div>

    </div>

    <div class="text-center mt-16">

      <a
        href="/founders"
        class="inline-flex items-center text-[#5D9C59] font-semibold hover:underline"
      >
        Learn More About Our Founders →
      </a>

    </div>

  </div>

</section>
