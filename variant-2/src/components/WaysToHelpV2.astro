---
const ways = [
  {
    title: "Donate",
    description: "Fund education resources, classroom support and mentorship for children who need consistent care.",
  },
  {
    title: "Volunteer",
    description: "Offer your time, skills and encouragement to help children learn with confidence.",
  },
  {
    title: "Partner",
    description: "Collaborate with us to expand community programs and reach more children with meaningful support.",
  },
];
---

<section class="bg-white py-20">
  <div class="max-w-5xl mx-auto px-6">
    <div class="grid gap-12 md:grid-cols-3">
      {ways.map((way) => (
        <article>
          <h2 class="text-3xl font-bold text-[#2F3A45]">
            {way.title}
          </h2>

          <p class="mt-5 text-gray-600 leading-relaxed">
            {way.description}
          </p>
        </article>
      ))}
    </div>
  </div>
</section>
