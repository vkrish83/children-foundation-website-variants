---
import storyImage from "../assets/programs.png";
---

<section class="bg-[#FAFAF8] py-20">

  <div class="max-w-7xl mx-auto px-6">

    <div class="grid lg:grid-cols-2 gap-16 items-center">

      <!-- Content -->

      <div>

        <p class="uppercase tracking-widest text-[#5D9C59] font-semibold mb-4">
          Our Story
        </p>

        <h2 class="text-5xl font-bold text-[#2F3A45] mb-8">
          Building Brighter Futures Together
        </h2>

        <p class="text-lg text-gray-600 leading-relaxed mb-6">
          Children First Foundation was created with a simple belief:
          every child deserves access to opportunities that help them
          learn, grow and succeed.
        </p>

        <p class="text-lg text-gray-600 leading-relaxed">
          Through education, mentorship and community support, we work
          alongside families and volunteers to help children discover
          their potential and create lasting positive change.
        </p>

      </div>

      <!-- Image -->

      <div>
        <img
          src={storyImage.src}
          alt="Our Story"
          class="w-full h-[500px] object-cover rounded-3xl"
        />
      </div>

    </div>

  </div>

</section>