---
const roles = [
  {
    title: "Mentor",
    description: "Guide children with patience, encouragement and conversations that build confidence.",
  },
  {
    title: "Education Support",
    description: "Help with reading, homework, activities and classroom support that keeps learning consistent.",
  },
  {
    title: "Community Outreach",
    description: "Work with families, local partners and volunteers to strengthen support around each child.",
  },
];
---

<section class="bg-white py-20">
  <div class="max-w-5xl mx-auto px-6">
    <div class="grid gap-12 md:grid-cols-3">
      {roles.map((role) => (
        <article>
          <h2 class="text-3xl font-bold text-[#2F3A45]">
            {role.title}
          </h2>

          <p class="mt-5 text-gray-600 leading-relaxed">
            {role.description}
          </p>
        </article>
      ))}
    </div>
  </div>
</section>
