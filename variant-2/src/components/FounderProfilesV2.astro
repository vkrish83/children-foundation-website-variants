---
import founder1 from "../assets/founder-1.png";
import founder2 from "../assets/founder-2.png";
import founder3 from "../assets/founder-3.png";

const founders = [
  {
    name: "Aravind Kumar",
    role: "Founder & Trustee",
    image: founder1,
    paragraphs: [
      "Aravind has spent years working with school communities across Tamil Nadu to make learning support more accessible for children.",
      "He focuses on building practical programs that connect education, mentorship and family participation.",
    ],
    imageFirst: true,
  },
  {
    name: "Suresh Narayanan",
    role: "Co-Founder",
    image: founder2,
    paragraphs: [
      "Suresh brings a deep commitment to community-led education and long-term support for first-generation learners.",
      "He helps shape partnerships with volunteers, local educators and families so children receive steady encouragement.",
    ],
    imageFirst: false,
  },
  {
    name: "Karthik Raman",
    role: "Program Lead",
    image: founder3,
    paragraphs: [
      "Karthik leads learning initiatives designed to help children build confidence in classrooms and beyond.",
      "His work centers on safe, supportive spaces where children can ask questions, practice skills and dream bigger.",
    ],
    imageFirst: true,
  },
];
---

<section class="bg-white py-20">
  <div class="max-w-5xl mx-auto px-6 space-y-20">
    {founders.map((founder) => (
      <article class="grid gap-10 md:grid-cols-2 md:items-center">
        <img
          src={founder.image.src}
          alt={founder.name}
          class:list={[
            "w-full rounded-3xl aspect-[4/5] object-cover",
            !founder.imageFirst && "md:order-2"
          ]}
        />

        <div class:list={[!founder.imageFirst && "md:order-1"]}>
          <h2 class="text-4xl md:text-5xl font-bold text-[#2F3A45] leading-tight">
            {founder.name}
          </h2>

          <p class="mt-3 text-[#5D9C59] font-semibold">
            {founder.role}
          </p>

          <p class="mt-8 text-lg text-gray-600 leading-relaxed">
            {founder.paragraphs[0]}
          </p>

          <p class="mt-5 text-lg text-gray-600 leading-relaxed">
            {founder.paragraphs[1]}
          </p>
        </div>
      </article>
    ))}
  </div>
</section>
