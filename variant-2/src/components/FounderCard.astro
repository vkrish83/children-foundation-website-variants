---
const { name, role, image, bio } = Astro.props;
---

<div class="bg-white rounded-3xl shadow-sm p-6 text-center">
  <img
    src={image}
    alt={name}
    class="w-32 h-32 mx-auto rounded-full object-cover mb-4"
  />

  <h3 class="text-2xl font-bold text-[#2F3A45]">
    {name}
  </h3>

  <p class="text-[#5D9C59] font-medium mb-4">
    {role}
  </p>

  <p class="text-gray-600">
    {bio}
  </p>
</div>