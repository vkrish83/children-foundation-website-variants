---
import storyImage from "../assets/featured-story-v2.png";
---

<section class="bg-white py-10">

  <div class="max-w-7xl mx-auto px-6">

    <div class="grid lg:grid-cols-2 gap-20 items-center">

      <!-- Image -->

      <div>
        <img
          src={storyImage.src}
          alt="Student Success Story"
          class="w-full rounded-3xl object-cover"
        />
      </div>

      <!-- Content -->

      <div>

        <p class="uppercase tracking-widest text-[#5D9C59] font-semibold">
          Featured Story
        </p>

        <h2 class="text-5xl font-bold text-[#2F3A45] mt-4">
          Meet Priya
        </h2>

        <p class="mt-8 text-lg text-gray-600 leading-relaxed">
          Priya dreamed of continuing her education, but access to resources was limited.
          Through community support and mentorship, she gained the confidence and opportunities
          needed to pursue her goals.
        </p>

        <p class="mt-6 text-lg text-gray-600 leading-relaxed">
          Today, she inspires other children in her community to believe in their own potential.
        </p>

        <a
          href="/stories"
          class="inline-block mt-8 text-[#5D9C59] font-semibold hover:underline"
        >
          Read More Stories →
        </a>

      </div>

    </div>

  </div>

</section>