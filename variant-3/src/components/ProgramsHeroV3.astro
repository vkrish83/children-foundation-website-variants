---
import programsImage from "../assets/programs.png";
---

<section class="bg-[#FAF7F2] pb-20 sm:pb-24">
  <div class="relative min-h-[88vh] overflow-hidden">
    <img
      src={programsImage.src}
      alt="Children learning together through a Children First program"
      class="absolute inset-0 h-full w-full object-cover"
    />

    <div class="absolute inset-0 bg-[#111827]/55"></div>
    <div class="absolute inset-0 bg-gradient-to-r from-[#111827]/80 via-[#111827]/45 to-transparent"></div>

    <div class="relative z-10 mx-auto flex min-h-[88vh] max-w-7xl items-center px-5 pb-16 pt-28 sm:px-6 lg:pt-32">
      <div class="max-w-5xl text-white">
        <p class="text-xs font-semibold uppercase tracking-[0.28em] text-[#F4B942] sm:text-sm">
        Our Programs
        </p>

        <h1 class="mt-6 text-5xl font-bold leading-[0.98] sm:text-6xl md:text-8xl">
          Support That Helps Children Move Forward.
        </h1>

        <p class="mt-8 max-w-3xl text-lg leading-8 text-white/85 md:text-2xl md:leading-10">
          Through education, mentorship and community care, our programs create steady support around children as they learn, grow and imagine what comes next.
        </p>
      </div>
    </div>
  </div>
</section>
