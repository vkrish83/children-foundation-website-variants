---
import heroImage from "../assets/volunteer-v3.png";
---

<section class="relative min-h-[88vh] overflow-hidden">
  <img
    src={heroImage.src}
    alt="Priya smiling with quiet confidence"
    class="absolute inset-0 h-full w-full object-cover"
  />

  <div class="absolute inset-0 bg-[#111827]/55"></div>
  <div class="absolute inset-0 bg-gradient-to-r from-[#111827]/80 via-[#111827]/45 to-transparent"></div>

  <div class="relative z-10 mx-auto flex min-h-[88vh] max-w-7xl items-center px-5 pb-16 pt-28 sm:px-6 lg:pt-32">
    <div class="max-w-4xl text-white">
      <p class="text-xs font-semibold uppercase tracking-[0.28em] text-[#F4B942] sm:text-sm">
        Stories
      </p>

      <h1 class="mt-6 text-6xl font-bold leading-[0.95] sm:text-7xl md:text-9xl">
        Real Stories.<br />
        Real Possibility.
      </h1>
    </div>
  </div>
</section>
