---
const values = [
  {
    name: "Education",
    text: "We create learning pathways that help children build skills, confidence and the courage to keep going.",
  },
  {
    name: "Dignity",
    text: "We meet every child with respect, patience and the belief that their story deserves to be heard fully.",
  },
  {
    name: "Community",
    text: "We work with families, volunteers and local partners so support becomes part of a child's everyday world.",
  },
];
---

<section class="bg-[#FAF7F2] py-20 sm:py-28">
  <div class="mx-auto max-w-7xl px-5 sm:px-6">
    <div class="max-w-4xl">
      <p class="text-xs font-semibold uppercase tracking-[0.28em] text-[#D97706] sm:text-sm">
        What Guides Us
      </p>

      <h2 class="mt-6 text-4xl font-bold leading-tight text-[#1F2937] sm:text-5xl md:text-7xl">
        Built on the values children should feel, not just hear.
      </h2>
    </div>

    <div class="mt-16 grid gap-10 border-t border-[#1F2937]/15 pt-10 md:grid-cols-3">
      {values.map((value) => (
        <section>
          <h3 class="text-3xl font-bold text-[#1F2937]">
            {value.name}
          </h3>

          <p class="mt-5 text-lg leading-8 text-[#1F2937]/70">
            {value.text}
          </p>
        </section>
      ))}
    </div>
  </div>
</section>
