---
import founder1 from "../assets/founder-1.png";
import founder2 from "../assets/founder-2.png";
import founder3 from "../assets/founder-3.png";

const founders = [
  { name: "Suresh Narayanan", role: "Co-Founder", image: founder2 },
  { name: "Karthik Raman", role: "Program Director", image: founder3 },
];
---

<section class="bg-white py-20 sm:py-24">
  <div class="mx-auto max-w-7xl px-5 sm:px-6">
    <p class="text-xs font-semibold uppercase tracking-[0.28em] text-[#D97706] sm:text-sm">
      Leadership
    </p>

    <h2 class="mt-5 max-w-4xl text-4xl font-bold leading-tight text-[#1F2937] sm:text-5xl md:text-6xl">
      Guided by people who believe every child matters.
    </h2>

    <div class="mt-16 grid items-start gap-14 lg:grid-cols-[1.12fr_0.88fr] lg:gap-16">
      <div>
        <img
          src={founder1.src}
          alt="Aravind Kumar"
          class="h-[520px] w-full rounded-[2rem] object-cover sm:h-[650px] lg:rounded-[3rem]"
        />

        <div class="mt-10 max-w-2xl">
          <p class="text-xs font-semibold uppercase tracking-[0.28em] text-[#D97706] sm:text-sm">
            Founder's Note
          </p>

          <h3 class="mt-4 text-3xl font-bold text-[#1F2937] sm:text-4xl">
            Aravind Kumar
          </h3>

          <p class="mt-6 text-xl leading-8 text-[#1F2937]/75 sm:text-2xl sm:leading-10">
            &ldquo;Every child deserves opportunity before they are asked to overcome challenges.&rdquo;
          </p>

          <a
            href="/founders"
            class="mt-8 inline-block font-semibold text-[#D97706] transition hover:text-[#1F2937]"
          >
            Read Our Story &rarr;
          </a>
        </div>
      </div>

      <div class="space-y-8 pt-0 lg:pt-24">
        {founders.map((founder, index) => (
          <article class={`grid items-end gap-6 sm:grid-cols-[180px_1fr] ${index === 1 ? "lg:ml-14" : ""}`}>
            <img
              src={founder.image.src}
              alt={founder.name}
              class="h-[230px] w-full rounded-[1.5rem] object-cover sm:h-[250px]"
            />

            <div class="pb-2">
              <h4 class="text-2xl font-bold text-[#1F2937]">
                {founder.name}
              </h4>

              <p class="mt-2 text-[#1F2937]/65">
                {founder.role}
              </p>
            </div>
          </article>
        ))}
      </div>
    </div>
  </div>
</section>
