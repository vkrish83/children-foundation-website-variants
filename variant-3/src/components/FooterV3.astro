---
const exploreLinks = ["About", "Programs", "Stories", "Founders"];
const actionLinks = ["Volunteer", "Donate", "Contact"];
---

<footer class="border-t border-white/10 bg-[#1F2937] py-16 text-white sm:py-20">
  <div class="mx-auto max-w-7xl px-5 sm:px-6">
    <div class="grid gap-14 lg:grid-cols-2 lg:gap-16">
      <div>
        <h2 class="text-5xl font-bold leading-tight md:text-7xl">
          Children First
        </h2>

        <p class="mt-8 max-w-lg leading-8 text-white/70">
          Building brighter futures through education,
          mentorship and community support.
        </p>
      </div>

      <div class="grid grid-cols-2 gap-10">
        <div>
          <h3 class="mb-6 font-semibold">Explore</h3>

          <ul class="space-y-3 text-white/70">
            {exploreLinks.map((label) => (
              <li>
                <a href={`/${label.toLowerCase()}`} class="transition hover:text-white">
                  {label}
                </a>
              </li>
            ))}
          </ul>
        </div>

        <div>
          <h3 class="mb-6 font-semibold">Get Involved</h3>

          <ul class="space-y-3 text-white/70">
            {actionLinks.map((label) => (
              <li>
                <a href={`/${label.toLowerCase()}`} class="transition hover:text-white">
                  {label}
                </a>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>

    <div class="mt-20 border-t border-white/10 pt-8 text-white/50">
      &copy; 2026 Children First Foundation
    </div>
  </div>
</footer>
