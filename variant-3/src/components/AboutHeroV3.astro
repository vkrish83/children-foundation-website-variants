---
import heroImage from "../assets/volunteer-v3.png";
---

<section class="relative min-h-[86vh] overflow-hidden">
  <img
    src={heroImage.src}
    alt="Children First volunteers spending time with children"
    class="absolute inset-0 h-full w-full object-cover"
  />

  <div class="absolute inset-0 bg-[#111827]/55"></div>
  <div class="absolute inset-0 bg-gradient-to-r from-[#111827]/80 via-[#111827]/45 to-transparent"></div>

  <div class="relative z-10 mx-auto flex min-h-[86vh] max-w-7xl items-center px-5 pb-16 pt-28 sm:px-6 lg:pt-32">
    <div class="max-w-4xl text-white">
      <p class="mb-6 text-xs font-semibold uppercase tracking-[0.28em] text-[#F4B942] sm:text-sm">
        About Children First
      </p>

      <h1 class="text-5xl font-bold leading-[0.98] sm:text-6xl md:text-8xl">
        We Believe Every Child Deserves The Chance To Dream.
      </h1>

      <p class="mt-8 max-w-2xl text-lg leading-8 text-white/85 md:text-2xl md:leading-10">
        Through education, mentorship and community care, we stand beside children as they build confidence, discover possibility and move toward brighter futures.
      </p>
    </div>
  </div>
</section>
