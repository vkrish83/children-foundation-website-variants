---
import heroImage from "../assets/hero-v3.png";
---

<section class="relative min-h-[82vh] overflow-hidden">
  <img
    src={heroImage.src}
    alt="Children First community moment"
    class="absolute inset-0 h-full w-full object-cover"
  />

  <div class="absolute inset-0 bg-[#111827]/60"></div>

  <div class="relative z-10 mx-auto flex min-h-[82vh] max-w-7xl items-center px-5 pb-16 pt-28 sm:px-6 lg:pt-32">
    <div class="max-w-4xl text-white">
      <p class="text-xs font-semibold uppercase tracking-[0.28em] text-[#F4B942] sm:text-sm">
        Contact
      </p>

      <h1 class="mt-6 text-5xl font-bold leading-[0.98] sm:text-6xl md:text-8xl">
        Let&apos;s Start A Conversation.
      </h1>

      <p class="mt-8 max-w-2xl text-lg leading-8 text-white/85 md:text-2xl md:leading-10">
        Whether you want to volunteer, partner or learn more, we would be glad to hear from you.
      </p>
    </div>
  </div>
</section>
