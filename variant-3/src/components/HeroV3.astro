---
import heroImage from "../assets/hero-v3.png";
---

<section class="relative min-h-screen overflow-hidden">
  <img
    src={heroImage.src}
    alt="Children sharing a hopeful moment"
    class="absolute inset-0 h-full w-full object-cover"
  />

  <div class="absolute inset-0 bg-[#111827]/60"></div>
  <div class="absolute inset-0 bg-gradient-to-r from-[#111827]/80 via-[#111827]/45 to-transparent"></div>

  <div class="relative z-10 mx-auto flex min-h-screen max-w-7xl items-center px-5 pb-16 pt-28 sm:px-6 lg:pt-32">
    <div class="max-w-4xl text-white">
      <p class="mb-6 text-xs font-semibold uppercase tracking-[0.28em] text-[#F4B942] sm:text-sm">
        Children First Foundation
      </p>

      <h1 class="text-5xl font-bold leading-[0.98] sm:text-6xl md:text-8xl">
        Every Child Deserves The Chance To Dream.
      </h1>

      <p class="mt-7 max-w-2xl text-lg leading-8 text-white/85 md:text-2xl md:leading-10">
        Human-first support for children, families, and communities building brighter futures together.
      </p>

      <div class="mt-10 flex flex-wrap gap-4">
        <a
          href="/about"
          class="rounded-full bg-white px-8 py-4 font-semibold text-[#1F2937] transition hover:bg-[#F4B942]"
        >
          Our Story
        </a>

        <a
          href="/volunteer"
          class="rounded-full border border-white/80 px-8 py-4 font-semibold text-white transition hover:bg-white hover:text-[#1F2937]"
        >
          Get Involved
        </a>
      </div>
    </div>
  </div>
</section>
