---
import contactImage from "../assets/volunteer-v3.png";

const details = [
  {
    label: "Email",
    value: "hello@childrenfirst.org",
  },
  {
    label: "Phone",
    value: "+91 98765 43210",
  },
  {
    label: "Location",
    value: "Bengaluru, India",
  },
];
---

<section class="bg-[#FAF7F2] py-20 sm:py-28">
  <div class="mx-auto grid max-w-7xl items-end gap-14 px-5 sm:px-6 lg:grid-cols-[1.05fr_0.95fr] lg:gap-16">
    <div>
      <p class="text-xs font-semibold uppercase tracking-[0.28em] text-[#D97706] sm:text-sm">
        Reach Us
      </p>

      <h2 class="mt-6 text-4xl font-bold leading-tight text-[#1F2937] sm:text-5xl md:text-7xl">
        We welcome partners, volunteers and people who care.
      </h2>

      <div class="mt-12 divide-y divide-[#1F2937]/15 border-y border-[#1F2937]/15">
        {details.map((detail) => (
          <div class="grid gap-2 py-6 sm:grid-cols-[160px_1fr] sm:gap-8">
            <p class="text-sm font-semibold uppercase tracking-[0.18em] text-[#D97706]">
              {detail.label}
            </p>

            <p class="text-xl font-semibold text-[#1F2937]">
              {detail.value}
            </p>
          </div>
        ))}
      </div>
    </div>

    <img
      src={contactImage.src}
      alt="A Children First volunteer connecting with children"
      class="h-[480px] w-full rounded-[2rem] object-cover sm:h-[620px] lg:rounded-[3rem]"
    />
  </div>
</section>
