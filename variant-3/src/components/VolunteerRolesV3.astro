---
import educationImage from "../assets/programs.png";
import mentorImage from "../assets/dream.png";
import communityImage from "../assets/volunteer-v3.png";

const roles = [
  {
    title: "Learning Support",
    text: "Help children with reading, schoolwork and the patient practice that builds confidence.",
    image: educationImage,
    alt: "Children taking part in a learning program",
  },
  {
    title: "Mentorship",
    text: "Offer encouragement, listen with care and help children imagine what is possible for them.",
    image: mentorImage,
    alt: "A child dreaming about the future",
  },
  {
    title: "Community Help",
    text: "Support events, family outreach and the local relationships that keep our work grounded.",
    image: communityImage,
    alt: "Volunteers sharing a community moment",
  },
];
---

<section class="bg-[#FAF7F2] py-20 sm:py-28">
  <div class="mx-auto max-w-7xl px-5 sm:px-6">
    <div class="max-w-4xl">
      <p class="text-xs font-semibold uppercase tracking-[0.28em] text-[#D97706] sm:text-sm">
        Volunteer Roles
      </p>

      <h2 class="mt-6 text-4xl font-bold leading-tight text-[#1F2937] sm:text-5xl md:text-7xl">
        Find a way to contribute that feels human and useful.
      </h2>
    </div>

    <div class="mt-16 space-y-16">
      {roles.map((role, index) => (
        <article class={`grid items-center gap-10 lg:gap-16 ${index % 2 === 0 ? "lg:grid-cols-[1.05fr_0.95fr]" : "lg:grid-cols-[0.95fr_1.05fr]"}`}>
          <img
            src={role.image.src}
            alt={role.alt}
            class={`h-[420px] w-full rounded-[2rem] object-cover lg:rounded-[3rem] ${index % 2 === 0 ? "" : "lg:order-2"} sm:h-[560px]`}
          />

          <div>
            <p class="text-xs font-semibold uppercase tracking-[0.28em] text-[#D97706] sm:text-sm">
              0{index + 1}
            </p>

            <h3 class="mt-5 text-4xl font-bold leading-tight text-[#1F2937] sm:text-5xl">
              {role.title}
            </h3>

            <p class="mt-6 max-w-xl text-lg leading-8 text-[#1F2937]/70 md:text-xl md:leading-9">
              {role.text}
            </p>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
