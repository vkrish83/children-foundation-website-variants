---
const stats = [
  { value: "500+", label: "Children Supported" },
  { value: "120+", label: "Volunteers" },
  { value: "12+", label: "Programs" },
  { value: "8+", label: "Communities" },
];
---

<section class="bg-[#1F2937] py-20 text-white sm:py-24">
  <div class="mx-auto max-w-7xl px-5 sm:px-6">
    <div class="grid items-center gap-16 lg:grid-cols-[1.08fr_0.92fr]">
      <div>
        <p class="text-xs font-semibold uppercase tracking-[0.28em] text-[#F4B942] sm:text-sm">
          Our Impact
        </p>

        <h2 class="mt-6 text-4xl font-bold leading-tight sm:text-5xl md:text-7xl">
          Small acts of care can change the direction of a child's life.
        </h2>
      </div>

      <div class="grid grid-cols-2 gap-x-8 gap-y-10">
        {stats.map((stat) => (
          <div class="border-t border-white/15 pt-6">
            <p class="text-5xl font-bold text-[#F4B942] md:text-6xl">{stat.value}</p>
            <p class="mt-3 text-sm font-medium uppercase tracking-[0.14em] text-white/70">
              {stat.label}
            </p>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
