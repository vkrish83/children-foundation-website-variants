---
const { amount, title, description } = Astro.props;
---

<div class="bg-white rounded-3xl shadow-sm p-8 text-center">

  <div class="text-4xl font-bold text-[#F4A261] mb-4">
    ₹{amount}
  </div>

  <h3 class="text-2xl font-semibold text-[#2F3A45] mb-3">
    {title}
  </h3>

  <p class="text-gray-600">
    {description}
  </p>

</div>