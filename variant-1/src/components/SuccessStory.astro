---
import successStory from '../assets/success.png';
---
<section class="bg-white py-24">
  <div class="max-w-7xl mx-auto px-6">

    <div class="grid md:grid-cols-2 gap-12 items-center">

      <!-- Story Image -->
      <div>
        <img
          src={successStory.src}
          alt="Children learning"
          class="w-full rounded-3xl shadow-lg"
        />
      </div>

      <!-- Story Content -->
      <div>

        <p class="text-[#5D9C59] uppercase tracking-wider font-semibold mb-4">
          Success Story
        </p>

        <h2 class="text-5xl font-bold text-[#2F3A45] mb-6">
          From Dreaming
          To Achieving
        </h2>

        <p class="text-gray-600 text-lg leading-relaxed mb-6">
          Through educational support and mentorship,
          children gain confidence to pursue their goals
          and build brighter futures for themselves and
          their communities.
        </p>

        <blockquote class="border-l-4 border-[#5D9C59] pl-6 italic text-xl text-[#2F3A45]">
          "I never thought I could become a teacher.
          Today I help other children learn."
        </blockquote>

        <p class="mt-6 font-semibold text-[#2F3A45]">
          — Future Educator Program Participant
        </p>

      </div>

    </div>

  </div>
</section>