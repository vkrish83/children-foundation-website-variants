---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import CallToAction from "../components/CallToAction.astro";
---

<Layout>
  <Navbar />

  <section class="bg-[#FFFDF7] py-24">
    <div class="max-w-6xl mx-auto px-6 text-center">

      <h1 class="text-6xl font-bold text-[#2F3A45]">
        Stories of Impact
      </h1>

      <p class="text-xl text-gray-600 mt-6 max-w-3xl mx-auto">
        Behind every number is a child whose life has
        been transformed through education and support.
      </p>

    </div>
  </section>

  <section class="py-20">
    <div class="max-w-6xl mx-auto px-6">

      <div class="bg-[#F2F8F0] rounded-3xl p-12 mb-16">

        <p class="text-[#5D9C59] font-semibold uppercase mb-4">
          Featured Story
        </p>

        <h2 class="text-4xl font-bold text-[#2F3A45] mb-6">
          Ananya's Journey
        </h2>

        <p class="text-lg text-gray-600 leading-relaxed">
          When Ananya first joined our learning program,
          she struggled with reading and lacked confidence
          in the classroom.
        </p>

        <p class="text-lg text-gray-600 leading-relaxed mt-4">
          Through mentorship, reading support and
          encouragement, she steadily improved her skills.
          Today, she is one of the strongest students in
          her class and dreams of becoming a teacher.
        </p>

      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">

        <div class="bg-white rounded-3xl shadow-sm p-8">
          <h3 class="text-2xl font-bold mb-4">
            Building Confidence Through Reading
          </h3>

          <p class="text-gray-600">
            A reading initiative that helped children
            discover the joy of books and storytelling.
          </p>
        </div>

        <div class="bg-white rounded-3xl shadow-sm p-8">
          <h3 class="text-2xl font-bold mb-4">
            A Community Learning Together
          </h3>

          <p class="text-gray-600">
            Families, volunteers and teachers working
            together to support young learners.
          </p>
        </div>

        <div class="bg-white rounded-3xl shadow-sm p-8">
          <h3 class="text-2xl font-bold mb-4">
            Finding Joy In Learning
          </h3>

          <p class="text-gray-600">
            Creative activities helping children engage
            with education in meaningful ways.
          </p>
        </div>

        <div class="bg-white rounded-3xl shadow-sm p-8">
          <h3 class="text-2xl font-bold mb-4">
            From Classroom To College
          </h3>

          <p class="text-gray-600">
            Supporting students throughout their academic
            journey and future aspirations.
          </p>
        </div>

        <div class="bg-white rounded-3xl shadow-sm p-8">
          <h3 class="text-2xl font-bold mb-4">
            Digital Skills For Tomorrow
          </h3>

          <p class="text-gray-600">
            Introducing technology and digital literacy
            to prepare children for the future.
          </p>
        </div>

        <div class="bg-white rounded-3xl shadow-sm p-8">
          <h3 class="text-2xl font-bold mb-4">
            Supporting Future Leaders
          </h3>

          <p class="text-gray-600">
            Encouraging leadership, responsibility and
            confidence among young learners.
          </p>
        </div>

      </div>

    </div>
  </section>

  <CallToAction />
  <Footer />
</Layout>