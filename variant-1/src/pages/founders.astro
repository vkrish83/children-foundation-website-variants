---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import FounderCard from "../components/FounderCard.astro";
import founderImage from '../assets/founder-1.png';
import FounderImage2 from '../assets/founder-2.png';
---

<Layout>

<Navbar />

<section class="py-20 bg-[#F7F7F3]">

  <div class="max-w-6xl mx-auto px-6">

    <div class="text-center mb-16">
      <h1 class="text-5xl font-bold text-[#2F3A45] mb-6">
        Meet The People Behind The Mission
      </h1>

      <p class="text-xl text-gray-600 max-w-3xl mx-auto">
        Children First Foundation began with a simple belief:
        every child deserves access to education,
        opportunity and a brighter future.
      </p>
    </div>

    <div class="grid md:grid-cols-2 gap-8">

      <FounderCard
        name="Founder Name"
        role="Founder & Trustee"
        image={founderImage.src}
        bio="Dedicated to creating educational opportunities for underserved children."
      />

      <FounderCard
        name="Co-Founder Name"
        role="Co-Founder"
        image={FounderImage2.src}
        bio="Passionate about empowering communities through education and mentorship."
      />

    </div>

  </div>

</section>

<section class="py-20">

  <div class="max-w-5xl mx-auto px-6">

    <h2 class="text-4xl font-bold text-center text-[#2F3A45] mb-12">
      Our Journey
    </h2>

    <div class="space-y-8">

      <div class="border-l-4 border-[#5D9C59] pl-6">
        <h3 class="font-bold text-xl">2020</h3>
        <p class="text-gray-600">
          Foundation established with a mission to support children's education.
        </p>
      </div>

      <div class="border-l-4 border-[#5D9C59] pl-6">
        <h3 class="font-bold text-xl">2022</h3>
        <p class="text-gray-600">
          Launched community learning programs.
        </p>
      </div>

      <div class="border-l-4 border-[#5D9C59] pl-6">
        <h3 class="font-bold text-xl">2025</h3>
        <p class="text-gray-600">
          Expanded support to multiple communities.
        </p>
      </div>

    </div>

  </div>

</section>

<Footer />

</Layout>