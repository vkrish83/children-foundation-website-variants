---
import Layout from '../layouts/Layout.astro';
import NavbarV4 from '../components/NavbarV4.astro';
import FooterV4 from '../components/FooterV4.astro';
---

<Layout>
  <NavbarV4 />
  <main class="bg-[#F9FAFB] text-[#111827]">
    <section class="mx-auto max-w-7xl px-5 py-20 sm:px-6 lg:px-8 lg:py-28">
      <div class="max-w-3xl">
        <p class="text-sm font-semibold uppercase tracking-[0.18em] text-[#2563EB]">Donate</p>
        <h1 class="mt-4 text-5xl font-bold leading-[1.05] sm:text-6xl">Support Impact</h1>
        <p class="mt-6 text-lg leading-8 text-gray-600">
          A simple Variant #4 placeholder for future donation options, funding priorities, and reporting commitments.
        </p>
      </div>
    </section>
  </main>
  <FooterV4 />
</Layout>
