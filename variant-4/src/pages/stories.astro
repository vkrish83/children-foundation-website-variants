---
import Layout from '../layouts/Layout.astro';
import NavbarV4 from '../components/NavbarV4.astro';
import StoriesHeroV4 from '../components/StoriesHeroV4.astro';
import CaseStudyFeatureV4 from '../components/CaseStudyFeatureV4.astro';
import CaseStudyGridV4 from '../components/CaseStudyGridV4.astro';
import OutcomeSummaryV4 from '../components/OutcomeSummaryV4.astro';
import FinalCTAV4 from '../components/FinalCTAV4.astro';
import FooterV4 from '../components/FooterV4.astro';
---

<Layout>
  <NavbarV4 />
  <StoriesHeroV4 />
  <CaseStudyFeatureV4 />
  <CaseStudyGridV4 />
  <OutcomeSummaryV4 />
  <FinalCTAV4
    headline="Support Programs That Deliver Measurable Outcomes."
    primaryLabel="Support Impact"
    primaryHref="/donate"
    secondaryLabel="Contact Us"
    secondaryHref="/contact"
  />
  <FooterV4 />
</Layout>
