---
import Layout from '../layouts/Layout.astro';
import NavbarV4 from '../components/NavbarV4.astro';
import ProgramsHeroV4 from '../components/ProgramsHeroV4.astro';
import ProgramPortfolioV4 from '../components/ProgramPortfolioV4.astro';
import ProgramDeliveryModelV4 from '../components/ProgramDeliveryModelV4.astro';
import ProgramReportingV4 from '../components/ProgramReportingV4.astro';
import FinalCTAV4 from '../components/FinalCTAV4.astro';
import FooterV4 from '../components/FooterV4.astro';
---

<Layout>
  <NavbarV4 />
  <ProgramsHeroV4 />
  <ProgramPortfolioV4 />
  <ProgramDeliveryModelV4 />
  <ProgramReportingV4 />
  <FinalCTAV4
    headline="Support Structured Programs That Last."
    text="Help strengthen education access, mentorship capacity and long-term community support."
    primaryLabel="Support Impact"
    primaryHref="/donate"
    secondaryLabel="Review Metrics"
    secondaryHref="#impact"
  />
  <FooterV4 />
</Layout>
