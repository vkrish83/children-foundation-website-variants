---
import Layout from '../layouts/Layout.astro';
import NavbarV4 from '../components/NavbarV4.astro';
import FoundersHeroV4 from '../components/FoundersHeroV4.astro';
import LeadershipOverviewV4 from '../components/LeadershipOverviewV4.astro';
import FounderProfilesReportV4 from '../components/FounderProfilesReportV4.astro';
import GovernanceModelV4 from '../components/GovernanceModelV4.astro';
import LeadershipMetricsV4 from '../components/LeadershipMetricsV4.astro';
import FinalCTAV4 from '../components/FinalCTAV4.astro';
import FooterV4 from '../components/FooterV4.astro';
---

<Layout>
  <NavbarV4 />
  <FoundersHeroV4 />
  <LeadershipOverviewV4 />
  <FounderProfilesReportV4 />
  <GovernanceModelV4 />
  <LeadershipMetricsV4 />
  <FinalCTAV4
    headline="Support Accountable Leadership And Long-Term Impact."
    text="Help Children First Foundation strengthen transparent operations, consistent program delivery and measurable education outcomes."
    primaryLabel="Support Impact"
    primaryHref="/donate"
    secondaryLabel="Contact Team"
    secondaryHref="/contact"
  />
  <FooterV4 />
</Layout>
