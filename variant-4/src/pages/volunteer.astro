---
import Layout from '../layouts/Layout.astro';
import NavbarV4 from '../components/NavbarV4.astro';
import VolunteerHeroV4 from '../components/VolunteerHeroV4.astro';
import VolunteerCapacityV4 from '../components/VolunteerCapacityV4.astro';
import VolunteerRolesV4 from '../components/VolunteerRolesV4.astro';
import VolunteerProcessV4 from '../components/VolunteerProcessV4.astro';
import VolunteerReportingV4 from '../components/VolunteerReportingV4.astro';
import FinalCTAV4 from '../components/FinalCTAV4.astro';
import FooterV4 from '../components/FooterV4.astro';
---

<Layout>
  <NavbarV4 />
  <VolunteerHeroV4 />
  <VolunteerCapacityV4 />
  <VolunteerRolesV4 />
  <VolunteerProcessV4 />
  <VolunteerReportingV4 />
  <FinalCTAV4
    headline="Build Capacity Through Volunteering."
    text="Join a structured volunteer program designed to support children consistently."
    primaryLabel="Apply To Volunteer"
    primaryHref="/contact"
    secondaryLabel="View Programs"
    secondaryHref="/programs"
  />
  <FooterV4 />
</Layout>
