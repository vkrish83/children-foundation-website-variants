---
const regions = [
  { name: 'North Cluster', children: '145', programs: 'Education + Mentorship', widthClass: 'w-[78%]' },
  { name: 'Central Cluster', children: '210', programs: 'Full Program Model', widthClass: 'w-full' },
  { name: 'South Cluster', children: '95', programs: 'Community Support', widthClass: 'w-[54%]' },
  { name: 'East Cluster', children: '50', programs: 'Volunteer Outreach', widthClass: 'w-[35%]' },
];
---

<section id="regions" class="bg-white">
  <div class="mx-auto max-w-7xl px-5 py-16 sm:px-6 lg:px-8">
    <div class="grid gap-10 lg:grid-cols-[0.9fr_1.1fr] lg:items-center">
      <div>
        <p class="text-sm font-semibold uppercase tracking-[0.18em] text-[#2563EB]">Communities Served</p>
        <h2 class="mt-3 text-3xl font-bold text-[#111827] sm:text-4xl">Reach Across Regions</h2>
        <p class="mt-5 text-base leading-7 text-gray-600">
          A simplified impact map showing how foundation resources are distributed across community clusters.
        </p>
        <div class="mt-8 grid grid-cols-2 gap-4">
          <div class="rounded-lg border border-gray-200 bg-[#F9FAFB] p-5">
            <p class="text-3xl font-bold text-[#111827]">8</p>
            <p class="mt-2 text-sm font-medium text-gray-600">Communities</p>
          </div>
          <div class="rounded-lg border border-gray-200 bg-[#F9FAFB] p-5">
            <p class="text-3xl font-bold text-[#111827]">4</p>
            <p class="mt-2 text-sm font-medium text-gray-600">Regional Clusters</p>
          </div>
        </div>
      </div>

      <div class="rounded-lg border border-gray-200 bg-[#F9FAFB] p-6 shadow-sm">
        <div class="mb-6 flex items-center justify-between border-b border-gray-200 pb-4">
          <div>
            <h3 class="text-lg font-bold text-[#111827]">Impact Distribution</h3>
            <p class="mt-1 text-sm text-gray-600">Children supported by regional cluster</p>
          </div>
          <span class="rounded bg-amber-100 px-3 py-1 text-xs font-semibold text-amber-800">FY 2026</span>
        </div>

        <div class="space-y-5">
          {regions.map((region) => (
            <div>
              <div class="mb-2 flex items-center justify-between gap-4">
                <div>
                  <p class="text-sm font-semibold text-[#111827]">{region.name}</p>
                  <p class="text-xs text-gray-500">{region.programs}</p>
                </div>
                <p class="text-sm font-bold text-[#0F766E]">{region.children}</p>
              </div>
              <div class="h-3 rounded-full bg-gray-200">
                <div class={`h-3 rounded-full bg-[#2563EB] ${region.widthClass}`}></div>
              </div>
            </div>
          ))}
        </div>

        <div class="mt-8 grid gap-3 sm:grid-cols-3">
          <div class="rounded border border-gray-200 bg-white p-4">
            <p class="text-xs font-semibold uppercase tracking-[0.14em] text-gray-500">Coverage</p>
            <p class="mt-2 text-xl font-bold text-[#111827]">72%</p>
          </div>
          <div class="rounded border border-gray-200 bg-white p-4">
            <p class="text-xs font-semibold uppercase tracking-[0.14em] text-gray-500">Growth</p>
            <p class="mt-2 text-xl font-bold text-[#0F766E]">+18%</p>
          </div>
          <div class="rounded border border-gray-200 bg-white p-4">
            <p class="text-xs font-semibold uppercase tracking-[0.14em] text-gray-500">Need</p>
            <p class="mt-2 text-xl font-bold text-[#F59E0B]">High</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
