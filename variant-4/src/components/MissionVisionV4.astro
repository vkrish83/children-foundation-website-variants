---
const cards = [
  {
    title: 'Mission',
    marker: 'M',
    text: 'To expand access to structured education, mentoring, and community support for children through measurable, accountable programs.',
    points: ['Program consistency', 'Child-centered delivery', 'Transparent reporting'],
  },
  {
    title: 'Vision',
    marker: 'V',
    text: 'A future where every child can build learning confidence, receive guidance, and stay connected to opportunity through local support systems.',
    points: ['Sustained participation', 'Community capacity', 'Long-term outcomes'],
  },
];
---

<section class="border-y border-gray-200 bg-white">
  <div class="mx-auto max-w-7xl px-5 py-16 sm:px-6 lg:px-8">
    <div class="mb-10 max-w-3xl">
      <p class="text-sm font-semibold uppercase tracking-[0.18em] text-[#0F766E]">Institutional Direction</p>
      <h2 class="mt-3 text-3xl font-bold text-[#111827] sm:text-4xl">Mission & Vision</h2>
    </div>

    <div class="grid gap-6 lg:grid-cols-2">
      {cards.map((card) => (
        <article class="rounded-lg border border-gray-200 bg-[#FFFFFF] p-6 shadow-sm lg:p-8">
          <div class="flex items-start gap-5">
            <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded bg-blue-50 text-sm font-bold text-[#2563EB]">
              {card.marker}
            </div>
            <div>
              <h3 class="text-2xl font-bold text-[#111827]">{card.title}</h3>
              <p class="mt-4 text-base leading-7 text-gray-600">{card.text}</p>
            </div>
          </div>
          <div class="mt-8 grid gap-3 sm:grid-cols-3">
            {card.points.map((point) => (
              <div class="rounded border border-gray-200 bg-[#F9FAFB] px-4 py-3 text-sm font-semibold text-gray-700">
                {point}
              </div>
            ))}
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
