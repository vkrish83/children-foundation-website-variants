---
const metrics = [
  { value: '120+', label: 'Active Volunteers' },
  { value: '64%', label: 'Volunteer Coverage' },
  { value: '36', label: 'Monthly Sessions' },
  { value: '8', label: 'Communities Supported' },
];
---

<section class="border-y border-gray-200 bg-white">
  <div class="mx-auto max-w-7xl px-5 py-16 sm:px-6 lg:px-8">
    <div class="rounded-lg border border-gray-200 bg-[#F9FAFB] shadow-sm">
      <div class="grid gap-6 border-b border-gray-200 p-6 lg:grid-cols-[0.85fr_1.15fr] lg:items-end lg:p-8">
        <div>
          <p class="text-sm font-semibold uppercase tracking-[0.18em] text-[#0F766E]">Capacity Dashboard</p>
          <h2 class="mt-3 text-3xl font-bold text-[#111827] sm:text-4xl">Volunteer Operating Capacity</h2>
        </div>
        <p class="text-base leading-7 text-gray-600">
          Current volunteer capacity is tracked through active participation, coverage, session volume, and community support.
        </p>
      </div>

      <div class="grid gap-0 sm:grid-cols-2 lg:grid-cols-4">
        {metrics.map((metric) => (
          <article class="border-b border-gray-200 bg-white p-6 last:border-b-0 lg:border-b-0 lg:border-r lg:last:border-r-0">
            <p class="text-4xl font-bold text-[#2563EB]">{metric.value}</p>
            <p class="mt-4 text-sm font-semibold uppercase tracking-[0.12em] text-gray-500">{metric.label}</p>
          </article>
        ))}
      </div>
    </div>
  </div>
</section>
