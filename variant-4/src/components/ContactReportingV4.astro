---
import volunteerImage from '../assets/volunteer-v4.png';

const items = [
  { label: 'Response Window', value: '2 business days' },
  { label: 'Program Reports', value: 'Available on request' },
  { label: 'Partnership Review', value: 'Monthly' },
  { label: 'Volunteer Intake', value: 'Ongoing' },
];
---

<section class="border-y border-gray-200 bg-white">
  <div class="mx-auto grid max-w-7xl gap-8 px-5 py-16 sm:px-6 lg:grid-cols-[0.78fr_1fr] lg:items-center lg:px-8">
    <div class="rounded-lg border border-gray-200 bg-[#F9FAFB] p-3">
      <img src={volunteerImage.src} alt="Volunteer coordination and foundation reporting" class="h-full min-h-[280px] w-full rounded-md object-cover" />
    </div>

    <div>
      <p class="text-sm font-semibold uppercase tracking-[0.18em] text-[#F59E0B]">Inquiry Reporting</p>
      <h2 class="mt-3 text-3xl font-bold text-[#111827] sm:text-4xl">Contact Operating Standards</h2>
      <div class="mt-8 grid gap-4 sm:grid-cols-2">
        {items.map((item) => (
          <div class="rounded-lg border border-gray-200 bg-[#F9FAFB] p-5">
            <p class="text-xs font-semibold uppercase tracking-[0.14em] text-gray-500">{item.label}</p>
            <p class="mt-3 text-xl font-bold text-[#111827]">{item.value}</p>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
