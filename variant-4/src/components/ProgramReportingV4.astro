---
const reports = [
  { label: 'Attendance Consistency', value: '74%', bar: 'w-[74%]', color: 'bg-[#2563EB]' },
  { label: 'Program Continuity', value: '86%', bar: 'w-[86%]', color: 'bg-[#0F766E]' },
  { label: 'Volunteer Coverage', value: '64%', bar: 'w-[64%]', color: 'bg-[#2563EB]' },
  { label: 'Regional Reach', value: '72%', bar: 'w-[72%]', color: 'bg-[#F59E0B]' },
];
---

<section class="border-y border-gray-200 bg-[#F9FAFB]">
  <div class="mx-auto max-w-7xl px-5 py-16 sm:px-6 lg:px-8">
    <div class="rounded-lg border border-gray-200 bg-white shadow-sm">
      <div class="grid gap-6 border-b border-gray-200 p-6 lg:grid-cols-[0.85fr_1.15fr] lg:items-end lg:p-8">
        <div>
        <p class="text-sm font-semibold uppercase tracking-[0.18em] text-[#F59E0B]">Annual Reporting</p>
          <h2 class="mt-3 text-3xl font-bold text-[#111827] sm:text-4xl">Reporting Dashboard</h2>
        </div>
        <div class="flex flex-col gap-3 text-sm text-gray-600 sm:flex-row sm:items-center sm:justify-end">
          <span class="rounded bg-blue-50 px-3 py-1 font-semibold text-[#2563EB]">FY 2026</span>
          <span class="rounded bg-[#F9FAFB] px-3 py-1 font-semibold text-gray-700">Program Operations</span>
        </div>
      </div>

      <div class="grid gap-0 lg:grid-cols-2">
        <div class="border-b border-gray-200 p-6 lg:border-b-0 lg:border-r lg:p-8">
          <p class="text-base leading-7 text-gray-600">
            Compact reporting rows provide an operations-level view of participation, continuity, volunteer coverage, and regional reach.
          </p>
          <div class="mt-6 grid grid-cols-2 gap-3">
            <div class="rounded border border-gray-200 bg-[#F9FAFB] p-4">
              <p class="text-xs font-semibold uppercase tracking-[0.14em] text-gray-500">Streams</p>
              <p class="mt-2 text-2xl font-bold text-[#111827]">3</p>
            </div>
            <div class="rounded border border-gray-200 bg-[#F9FAFB] p-4">
              <p class="text-xs font-semibold uppercase tracking-[0.14em] text-gray-500">Cycle</p>
              <p class="mt-2 text-2xl font-bold text-[#111827]">Monthly</p>
            </div>
          </div>
        </div>

        <div class="space-y-5 p-6 lg:p-8">
          {reports.map((report) => (
            <div>
              <div class="mb-2 flex items-center justify-between gap-4">
                <p class="text-sm font-semibold text-[#111827]">{report.label}</p>
                <p class="text-sm font-bold text-[#111827]">{report.value}</p>
              </div>
              <div class="h-3 rounded-full bg-gray-200">
                <div class={`h-3 rounded-full ${report.color} ${report.bar}`}></div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>
