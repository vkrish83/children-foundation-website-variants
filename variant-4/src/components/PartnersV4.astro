---
const partners = [
  'Northbridge Learning Trust',
  'BrightPath Volunteers',
  'Civic Health Network',
  'Future Skills Lab',
  'Community Action Forum',
  'Open Books Initiative',
];
---

<section id="partners" class="border-y border-gray-200 bg-[#F9FAFB]">
  <div class="mx-auto max-w-7xl px-5 py-16 sm:px-6 lg:px-8">
    <div class="mb-10 flex flex-col justify-between gap-5 md:flex-row md:items-end">
      <div>
        <p class="text-sm font-semibold uppercase tracking-[0.18em] text-[#0F766E]">Partner Network</p>
        <h2 class="mt-3 text-3xl font-bold text-[#111827] sm:text-4xl">Built With Accountable Partners</h2>
      </div>
      <p class="max-w-xl text-base leading-7 text-gray-600">
        Placeholder partner organizations shown in a clean institutional layout for future logos and verification details.
      </p>
    </div>

    <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {partners.map((partner) => (
        <div class="flex min-h-28 items-center justify-between rounded-lg border border-gray-200 bg-white p-6 shadow-sm">
          <div>
            <p class="text-base font-bold text-[#111827]">{partner}</p>
            <p class="mt-2 text-sm text-gray-500">Program Partner</p>
          </div>
          <div class="flex h-12 w-12 items-center justify-center rounded bg-blue-50 text-sm font-bold text-[#2563EB]">
            {partner.split(' ').map((word) => word[0]).slice(0, 2).join('')}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
