---
const outcomes = [
  {
    title: 'Learning Access',
    measure: 'Tracks recurring participation in study sessions and learning support touchpoints.',
    value: '500+',
  },
  {
    title: 'Confidence Building',
    measure: 'Measures reading confidence, classroom participation, and child-reported learning comfort.',
    value: '38%',
  },
  {
    title: 'Family Participation',
    measure: 'Monitors family follow-ups, local coordination, and continued engagement across cycles.',
    value: '64%',
  },
  {
    title: 'Volunteer Capacity',
    measure: 'Tracks active volunteer pool, monthly retention, and delivery coverage by region.',
    value: '120+',
  },
];
---

<section id="impact" class="bg-[#F9FAFB]">
  <div class="mx-auto max-w-7xl px-5 py-16 sm:px-6 lg:px-8">
    <div class="mb-10 max-w-3xl">
      <p class="text-sm font-semibold uppercase tracking-[0.18em] text-[#2563EB]">Outcome Measures</p>
      <h2 class="mt-3 text-3xl font-bold text-[#111827] sm:text-4xl">Program Outcomes</h2>
      <p class="mt-4 text-base leading-7 text-gray-600">
        Each outcome area maps to a practical measurement pattern used across program reviews.
      </p>
    </div>

    <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-4">
      {outcomes.map((outcome) => (
        <article class="rounded-lg border border-gray-200 bg-white p-6 shadow-sm">
          <p class="text-3xl font-bold text-[#2563EB]">{outcome.value}</p>
          <h3 class="mt-5 text-lg font-bold text-[#111827]">{outcome.title}</h3>
          <p class="mt-3 text-sm leading-6 text-gray-600">{outcome.measure}</p>
        </article>
      ))}
    </div>
  </div>
</section>
