---
const outcomes = [
  { value: '74%', label: 'Attendance Consistency', bar: 'w-[74%]', color: 'bg-[#2563EB]' },
  { value: '86%', label: 'Program Continuity', bar: 'w-[86%]', color: 'bg-[#0F766E]' },
  { value: '64%', label: 'Volunteer Coverage', bar: 'w-[64%]', color: 'bg-[#2563EB]' },
  { value: '72%', label: 'Regional Reach', bar: 'w-[72%]', color: 'bg-[#F59E0B]' },
  { value: '18%', label: 'Growth', bar: 'w-[18%]', color: 'bg-[#0F766E]' },
];
---

<section id="impact" class="border-y border-gray-200 bg-white">
  <div class="mx-auto max-w-7xl px-5 py-16 sm:px-6 lg:px-8">
    <div class="rounded-lg border border-gray-200 bg-[#F9FAFB] shadow-sm">
      <div class="grid gap-6 border-b border-gray-200 p-6 lg:grid-cols-[0.9fr_1.1fr] lg:items-end lg:p-8">
        <div>
          <p class="text-sm font-semibold uppercase tracking-[0.18em] text-[#F59E0B]">Annual Outcomes Summary</p>
          <h2 class="mt-3 text-3xl font-bold text-[#111827] sm:text-4xl">Case Study Outcome Indicators</h2>
        </div>
        <p class="text-base leading-7 text-gray-600">
          Aggregate indicators from reviewed cases and program reporting cycles.
        </p>
      </div>

      <div class="grid gap-0 lg:grid-cols-[0.75fr_1.25fr]">
        <div class="border-b border-gray-200 bg-white p-6 lg:border-b-0 lg:border-r lg:p-8">
          <p class="text-sm font-semibold uppercase tracking-[0.16em] text-gray-500">Reviewed Set</p>
          <p class="mt-4 text-5xl font-bold text-[#111827]">24</p>
          <p class="mt-3 text-sm leading-6 text-gray-600">
            Case reviews consolidated across education, mentorship, and community support programs.
          </p>
        </div>

        <div class="space-y-5 p-6 lg:p-8">
          {outcomes.map((outcome) => (
            <div>
              <div class="mb-2 flex items-center justify-between gap-4">
                <p class="text-sm font-semibold text-[#111827]">{outcome.label}</p>
                <p class="text-sm font-bold text-[#111827]">{outcome.value}</p>
              </div>
              <div class="h-3 rounded-full bg-gray-200">
                <div class={`h-3 rounded-full ${outcome.color} ${outcome.bar}`}></div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>
