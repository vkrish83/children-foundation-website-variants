---
interface Props {
  eyebrow?: string;
  headline?: string;
  text?: string;
  primaryLabel?: string;
  primaryHref?: string;
  secondaryLabel?: string;
  secondaryHref?: string;
}

const {
  eyebrow = 'Support The Next Reporting Cycle',
  headline = 'Help Create Lasting Impact.',
  text = 'Fund measurable programs, strengthen community delivery, and help more children stay connected to learning and mentorship.',
  primaryLabel = 'Partner With Us',
  primaryHref = 'mailto:hello@example.org',
  secondaryLabel = 'Review Metrics',
  secondaryHref = '#impact',
} = Astro.props;
---

<section id="support" class="bg-white">
  <div class="mx-auto max-w-7xl px-5 py-16 sm:px-6 lg:px-8">
    <div class="grid gap-8 rounded-lg bg-[#2563EB] p-8 text-white shadow-lg shadow-blue-600/20 md:grid-cols-[1fr_auto] md:items-center lg:p-10">
      <div>
        <p class="text-sm font-semibold uppercase tracking-[0.18em] text-blue-100">{eyebrow}</p>
        <h2 class="mt-3 text-3xl font-bold sm:text-4xl">{headline}</h2>
        <p class="mt-4 max-w-2xl text-base leading-7 text-blue-50">
          {text}
        </p>
      </div>
      <div class="flex flex-col gap-3 sm:flex-row md:flex-col lg:flex-row">
        <a href={primaryHref} class="inline-flex items-center justify-center rounded-md bg-white px-6 py-3 text-sm font-semibold text-[#2563EB] hover:bg-blue-50">
          {primaryLabel}
        </a>
        <a href={secondaryHref} class="inline-flex items-center justify-center rounded-md border border-white/40 px-6 py-3 text-sm font-semibold text-white hover:bg-white/10">
          {secondaryLabel}
        </a>
      </div>
    </div>
  </div>
</section>
