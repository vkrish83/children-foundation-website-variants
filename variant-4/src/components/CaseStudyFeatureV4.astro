---
import storyImage from '../assets/story-girl.png';

const caseItems = [
  {
    label: 'Challenge',
    text: 'Irregular attendance and low learning confidence.',
  },
  {
    label: 'Action',
    text: 'Weekly educational support and mentoring.',
  },
  {
    label: 'Outcome',
    text: 'Attendance improved by 74% and reading confidence increased.',
  },
];
---

<section class="border-y border-gray-200 bg-white">
  <div class="mx-auto max-w-7xl px-5 py-16 sm:px-6 lg:px-8">
    <div class="mb-10 flex flex-col justify-between gap-5 md:flex-row md:items-end">
      <div>
        <p class="text-sm font-semibold uppercase tracking-[0.18em] text-[#0F766E]">Featured Case Review</p>
        <h2 class="mt-3 text-3xl font-bold text-[#111827] sm:text-4xl">Education Support Case Study</h2>
      </div>
      <p class="max-w-xl text-base leading-7 text-gray-600">
        A structured case review using the Challenge, Action, Outcome format.
      </p>
    </div>

    <article class="grid overflow-hidden rounded-lg border border-gray-200 bg-[#F9FAFB] shadow-sm lg:grid-cols-[0.72fr_1.28fr]">
      <div class="border-b border-gray-200 bg-white p-5 lg:border-b-0 lg:border-r">
        <img src={storyImage.src} alt="Education support case study participant" class="h-72 w-full rounded-md object-cover lg:h-full" />
      </div>

      <div class="p-6 lg:p-8">
        <div class="mb-6 flex flex-wrap items-center justify-between gap-3 border-b border-gray-200 pb-5">
          <div>
            <h3 class="text-2xl font-bold text-[#111827]">Case Review 01</h3>
            <p class="mt-1 text-sm text-gray-600">Education stream / community learning cycle</p>
          </div>
          <span class="rounded bg-blue-50 px-3 py-1 text-xs font-semibold text-[#2563EB]">Reviewed</span>
        </div>

        <div class="grid gap-4">
          {caseItems.map((item) => (
            <section class="rounded-md border border-gray-200 bg-white p-5">
              <p class="text-xs font-semibold uppercase tracking-[0.16em] text-[#F59E0B]">{item.label}</p>
              <p class="mt-3 text-base leading-7 text-gray-700">{item.text}</p>
            </section>
          ))}
        </div>
      </div>
    </article>
  </div>
</section>
