---
import heroImage from '../assets/hero-v4.png';

const stats = [
  { value: '500+', label: 'Children Supported' },
  { value: '120+', label: 'Volunteers' },
  { value: '8', label: 'Communities' },
];
---

<section class="bg-[#F9FAFB]">
  <div class="mx-auto grid max-w-7xl gap-10 px-5 py-16 sm:px-6 lg:grid-cols-[1.08fr_0.92fr] lg:px-8 lg:py-24">
    <div class="flex flex-col justify-center">
      <p class="mb-5 inline-flex w-fit rounded-full border border-blue-200 bg-white px-4 py-2 text-xs font-semibold uppercase tracking-[0.18em] text-[#2563EB]">
        2026 Impact Overview
      </p>
      <h1 class="max-w-3xl text-5xl font-bold leading-[1.05] tracking-normal text-[#111827] sm:text-6xl lg:text-7xl">
        Helping Children Build Better Futures.
      </h1>
      <p class="mt-6 max-w-2xl text-lg leading-8 text-gray-600">
        A structured foundation model focused on education access, mentorship continuity, and community-led support for children.
      </p>

      <div class="mt-10 flex flex-col gap-3 sm:flex-row">
        <a href="#impact" class="inline-flex items-center justify-center rounded-md bg-[#2563EB] px-6 py-3 text-sm font-semibold text-white shadow-sm shadow-blue-600/20 hover:bg-blue-700">
          View Impact
        </a>
        <a href="#programs" class="inline-flex items-center justify-center rounded-md border border-gray-300 bg-white px-6 py-3 text-sm font-semibold text-[#111827] hover:border-[#2563EB] hover:text-[#2563EB]">
          Explore Programs
        </a>
      </div>
    </div>

    <div class="grid gap-5">
      <div class="overflow-hidden rounded-lg border border-gray-200 bg-white shadow-sm">
        <img src={heroImage.src} alt="Children participating in foundation programs" class="h-72 w-full object-cover sm:h-96" />
      </div>

      <div class="grid grid-cols-1 gap-4 sm:grid-cols-3">
        {stats.map((stat) => (
          <div class="rounded-lg border border-gray-200 bg-white p-5 shadow-sm">
            <p class="text-3xl font-bold text-[#111827]">{stat.value}</p>
            <p class="mt-2 text-sm font-medium text-gray-600">{stat.label}</p>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
