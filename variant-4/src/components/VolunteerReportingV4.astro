---
const reports = [
  { label: 'Volunteer Retention', value: '78%', bar: 'w-[78%]', color: 'bg-[#2563EB]' },
  { label: 'Monthly Participation', value: '64%', bar: 'w-[64%]', color: 'bg-[#0F766E]' },
  { label: 'Training Completion', value: '82%', bar: 'w-[82%]', color: 'bg-[#2563EB]' },
  { label: 'Field Coverage', value: '72%', bar: 'w-[72%]', color: 'bg-[#F59E0B]' },
];
---

<section id="impact" class="border-y border-gray-200 bg-[#F9FAFB]">
  <div class="mx-auto max-w-7xl px-5 py-16 sm:px-6 lg:px-8">
    <div class="rounded-lg border border-gray-200 bg-white shadow-sm">
      <div class="grid gap-6 border-b border-gray-200 p-6 lg:grid-cols-[0.9fr_1.1fr] lg:items-end lg:p-8">
        <div>
          <p class="text-sm font-semibold uppercase tracking-[0.18em] text-[#F59E0B]">Volunteer Reporting</p>
          <h2 class="mt-3 text-3xl font-bold text-[#111827] sm:text-4xl">Capacity Reporting Dashboard</h2>
        </div>
        <p class="text-base leading-7 text-gray-600">
          Compact indicators track retention, participation, training readiness, and field coverage.
        </p>
      </div>

      <div class="grid gap-0 lg:grid-cols-[0.72fr_1.28fr]">
        <div class="border-b border-gray-200 bg-[#F9FAFB] p-6 lg:border-b-0 lg:border-r lg:p-8">
          <p class="text-sm font-semibold uppercase tracking-[0.16em] text-gray-500">Review Cadence</p>
          <p class="mt-4 text-4xl font-bold text-[#111827]">Monthly</p>
          <p class="mt-3 text-sm leading-6 text-gray-600">
            Volunteer capacity is reviewed against role coverage and program delivery needs.
          </p>
        </div>

        <div class="space-y-5 p-6 lg:p-8">
          {reports.map((report) => (
            <div>
              <div class="mb-2 flex items-center justify-between gap-4">
                <p class="text-sm font-semibold text-[#111827]">{report.label}</p>
                <p class="text-sm font-bold text-[#111827]">{report.value}</p>
              </div>
              <div class="h-3 rounded-full bg-gray-200">
                <div class={`h-3 rounded-full ${report.color} ${report.bar}`}></div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>
