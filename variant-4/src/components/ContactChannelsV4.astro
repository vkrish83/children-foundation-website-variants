---
const channels = [
  { label: 'Email', value: 'hello@example.org', detail: 'Partnerships, programs and general inquiries', accent: 'text-[#2563EB]' },
  { label: 'Phone', value: '+91 98765 43210', detail: 'Foundation operations desk', accent: 'text-[#0F766E]' },
  { label: 'Location', value: 'Chennai, Tamil Nadu', detail: 'Regional coordination office', accent: 'text-[#2563EB]' },
  { label: 'Reporting', value: 'Annual Impact Report', detail: 'Program documentation and reporting requests', accent: 'text-[#F59E0B]' },
];
---

<section class="border-y border-gray-200 bg-white">
  <div class="mx-auto max-w-7xl px-5 py-16 sm:px-6 lg:px-8">
    <div class="mb-10 flex flex-col justify-between gap-5 md:flex-row md:items-end">
      <div>
        <p class="text-sm font-semibold uppercase tracking-[0.18em] text-[#0F766E]">Contact Channels</p>
        <h2 class="mt-3 text-3xl font-bold text-[#111827] sm:text-4xl">Foundation Access Points</h2>
      </div>
      <p class="max-w-xl text-base leading-7 text-gray-600">
        Direct inquiries to the appropriate operations channel for faster review and routing.
      </p>
    </div>

    <div class="grid gap-5 md:grid-cols-2 lg:grid-cols-4">
      {channels.map((channel) => (
        <article class="rounded-lg border border-gray-200 bg-[#F9FAFB] p-6">
          <p class="text-xs font-semibold uppercase tracking-[0.14em] text-gray-500">{channel.label}</p>
          <h3 class={`mt-3 text-xl font-bold ${channel.accent}`}>{channel.value}</h3>
          <p class="mt-4 border-t border-gray-200 pt-4 text-sm leading-6 text-gray-600">{channel.detail}</p>
        </article>
      ))}
    </div>
  </div>
</section>
