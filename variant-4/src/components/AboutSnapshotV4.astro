---
const metrics = [
  { value: '500+', label: 'Children Supported' },
  { value: '3200', label: 'Learning Hours' },
  { value: '120+', label: 'Volunteers' },
  { value: '86%', label: 'Program Continuity' },
];
---

<section id="impact" class="bg-[#F9FAFB]">
  <div class="mx-auto max-w-7xl px-5 py-16 sm:px-6 lg:px-8">
    <div class="mb-10 flex flex-col justify-between gap-5 md:flex-row md:items-end">
      <div>
        <p class="text-sm font-semibold uppercase tracking-[0.18em] text-[#F59E0B]">Foundation Snapshot</p>
        <h2 class="mt-3 text-3xl font-bold text-[#111827] sm:text-4xl">Current Operating Scale</h2>
      </div>
      <p class="max-w-xl text-base leading-7 text-gray-600">
        Core indicators used to track reach, engagement, volunteer capacity, and program consistency.
      </p>
    </div>

    <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-4">
      {metrics.map((metric) => (
        <article class="rounded-lg border border-gray-200 bg-white p-6 shadow-sm shadow-gray-200/70">
          <p class="text-4xl font-bold text-[#2563EB]">{metric.value}</p>
          <p class="mt-4 text-sm font-semibold uppercase tracking-[0.12em] text-gray-500">{metric.label}</p>
        </article>
      ))}
    </div>
  </div>
</section>
