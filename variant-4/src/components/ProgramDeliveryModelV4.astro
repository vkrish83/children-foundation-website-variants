---
const steps = [
  {
    number: '01',
    title: 'Assess',
    text: 'Review child needs, attendance patterns, community capacity, and partner availability.',
  },
  {
    number: '02',
    title: 'Plan',
    text: 'Define program schedule, volunteer allocation, materials, and local coordination points.',
  },
  {
    number: '03',
    title: 'Deliver',
    text: 'Run sessions, mentor check-ins, family coordination, and community support activities.',
  },
  {
    number: '04',
    title: 'Review',
    text: 'Compare participation, continuity, follow-ups, and regional delivery against targets.',
  },
  {
    number: '05',
    title: 'Improve',
    text: 'Refine schedules, volunteer coverage, partner workflows, and next-cycle priorities.',
  },
];
---

<section class="bg-white">
  <div class="mx-auto max-w-7xl px-5 py-16 sm:px-6 lg:px-8">
    <div class="mb-12 flex flex-col justify-between gap-5 md:flex-row md:items-end">
      <div>
        <p class="text-sm font-semibold uppercase tracking-[0.18em] text-[#0F766E]">Delivery Model</p>
        <h2 class="mt-3 text-3xl font-bold text-[#111827] sm:text-4xl">Operations Workflow</h2>
      </div>
      <p class="max-w-xl text-base leading-7 text-gray-600">
        A five-step workflow keeps assessment, planning, delivery, review, and improvement connected across program cycles.
      </p>
    </div>

    <div class="grid border border-gray-200 bg-[#F9FAFB] md:grid-cols-5">
      {steps.map((step) => (
        <article class="border-b border-gray-200 p-5 last:border-b-0 md:border-b-0 md:border-r md:last:border-r-0">
          <p class="text-sm font-bold text-[#2563EB]">{step.number}</p>
          <h3 class="mt-5 text-xl font-bold text-[#111827]">{step.title}</h3>
          <p class="mt-4 text-sm leading-6 text-gray-600">{step.text}</p>
        </article>
      ))}
    </div>
  </div>
</section>
