---
const inquiryTypes = ['Partnership', 'Volunteer', 'Donation', 'Program Inquiry', 'General'];
---

<section id="contact-form" class="bg-[#F9FAFB]">
  <div class="mx-auto grid max-w-7xl gap-8 px-5 py-16 sm:px-6 lg:grid-cols-[0.85fr_1.15fr] lg:px-8">
    <div>
      <p class="text-sm font-semibold uppercase tracking-[0.18em] text-[#2563EB]">Inquiry Form</p>
      <h2 class="mt-3 text-3xl font-bold text-[#111827] sm:text-4xl">Submit An Inquiry</h2>
      <p class="mt-5 max-w-lg text-base leading-7 text-gray-600">
        Share the inquiry type and relevant context so the foundation team can route the request to the right operating area.
      </p>
    </div>

    <form class="rounded-lg border border-gray-200 bg-white p-6 shadow-sm lg:p-8">
      <div class="grid gap-5 sm:grid-cols-2">
        <div>
          <label for="name" class="block text-sm font-semibold text-[#111827]">Name</label>
          <input id="name" name="name" type="text" autocomplete="name" class="mt-2 w-full rounded-md border border-gray-300 bg-white px-4 py-3 text-sm text-[#111827] outline-none focus:border-[#2563EB] focus:ring-2 focus:ring-blue-100" />
        </div>
        <div>
          <label for="email" class="block text-sm font-semibold text-[#111827]">Email</label>
          <input id="email" name="email" type="email" autocomplete="email" class="mt-2 w-full rounded-md border border-gray-300 bg-white px-4 py-3 text-sm text-[#111827] outline-none focus:border-[#2563EB] focus:ring-2 focus:ring-blue-100" />
        </div>
      </div>

      <div class="mt-5">
        <label for="inquiry-type" class="block text-sm font-semibold text-[#111827]">Inquiry Type</label>
        <select id="inquiry-type" name="inquiry-type" class="mt-2 w-full rounded-md border border-gray-300 bg-white px-4 py-3 text-sm text-[#111827] outline-none focus:border-[#2563EB] focus:ring-2 focus:ring-blue-100">
          {inquiryTypes.map((type) => (
            <option>{type}</option>
          ))}
        </select>
      </div>

      <div class="mt-5">
        <label for="message" class="block text-sm font-semibold text-[#111827]">Message</label>
        <textarea id="message" name="message" rows="6" class="mt-2 w-full rounded-md border border-gray-300 bg-white px-4 py-3 text-sm text-[#111827] outline-none focus:border-[#2563EB] focus:ring-2 focus:ring-blue-100"></textarea>
      </div>

      <button type="submit" class="mt-6 inline-flex items-center justify-center rounded-md bg-[#2563EB] px-6 py-3 text-sm font-semibold text-white shadow-sm shadow-blue-600/20 hover:bg-blue-700">
        Submit Inquiry
      </button>
    </form>
  </div>
</section>
