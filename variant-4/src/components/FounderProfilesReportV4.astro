---
import founderOne from '../assets/founder-1.png';
import founderTwo from '../assets/founder-2.png';
import founderThree from '../assets/founder-3.png';

const founders = [
  {
    name: 'Aravind Kumar',
    role: 'Founder',
    image: founderOne,
    responsibility: 'Foundation strategy and governance alignment',
    focus: 'Long-term education impact',
    reporting: 'Board-level operating review',
  },
  {
    name: 'Suresh Narayanan',
    role: 'Co-Founder',
    image: founderTwo,
    responsibility: 'Institutional partnerships and resource planning',
    focus: 'Community and donor coordination',
    reporting: 'Partnership pipeline review',
  },
  {
    name: 'Karthik Raman',
    role: 'Program Director',
    image: founderThree,
    responsibility: 'Program delivery and volunteer coordination',
    focus: 'Continuity across active communities',
    reporting: 'Monthly program indicators',
  },
];
---

<section class="bg-[#F9FAFB]">
  <div class="mx-auto max-w-7xl px-5 py-16 sm:px-6 lg:px-8">
    <div class="mb-10 flex flex-col justify-between gap-5 md:flex-row md:items-end">
      <div>
        <p class="text-sm font-semibold uppercase tracking-[0.18em] text-[#2563EB]">Founder Profiles</p>
        <h2 class="mt-3 text-3xl font-bold text-[#111827] sm:text-4xl">Leadership Register</h2>
      </div>
      <p class="max-w-xl text-base leading-7 text-gray-600">
        Founder roles are documented by responsibility, focus area and reporting contribution.
      </p>
    </div>

    <div class="grid gap-6 lg:grid-cols-3">
      {founders.map((founder) => (
        <article class="rounded-lg border border-gray-200 bg-white shadow-sm">
          <img src={founder.image.src} alt={founder.name} class="h-64 w-full rounded-t-lg object-cover" />
          <div class="p-6">
            <p class="text-sm font-semibold text-[#2563EB]">{founder.role}</p>
            <h3 class="mt-2 text-2xl font-bold text-[#111827]">{founder.name}</h3>
            <dl class="mt-6 space-y-4 border-t border-gray-200 pt-5">
              <div>
                <dt class="text-xs font-semibold uppercase tracking-[0.14em] text-gray-500">Responsibility</dt>
                <dd class="mt-1 text-sm leading-6 text-gray-700">{founder.responsibility}</dd>
              </div>
              <div>
                <dt class="text-xs font-semibold uppercase tracking-[0.14em] text-gray-500">Focus Area</dt>
                <dd class="mt-1 text-sm leading-6 text-gray-700">{founder.focus}</dd>
              </div>
              <div>
                <dt class="text-xs font-semibold uppercase tracking-[0.14em] text-gray-500">Reporting Role</dt>
                <dd class="mt-1 text-sm leading-6 text-gray-700">{founder.reporting}</dd>
              </div>
            </dl>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
