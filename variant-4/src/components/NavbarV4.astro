---
const links = [
  { label: 'About', href: '/about' },
  { label: 'Programs', href: '/programs' },
  { label: 'Stories', href: '/stories' },
  { label: 'Founders', href: '/founders' },
  { label: 'Volunteer', href: '/volunteer' },
  { label: 'Contact', href: '/contact' },
];
---

<header class="sticky top-0 z-50 border-b border-gray-200 bg-white/95 backdrop-blur">
  <nav class="mx-auto flex max-w-7xl items-center justify-between px-5 py-4 sm:px-6 lg:px-8" aria-label="Primary navigation">
    <a href="/" class="flex items-center gap-3">
      <span class="flex h-10 w-10 items-center justify-center rounded bg-[#2563EB] text-sm font-bold text-white">CF</span>
      <span class="text-sm font-semibold uppercase tracking-[0.16em] text-[#111827]">Children First</span>
    </a>

    <div class="hidden items-center gap-6 text-sm font-medium text-gray-600 lg:flex">
      {links.map((link) => (
        <a href={link.href} class="hover:text-[#2563EB]">{link.label}</a>
      ))}
    </div>

    <a href="/donate" class="inline-flex items-center justify-center rounded-md bg-[#2563EB] px-4 py-2 text-sm font-semibold text-white shadow-sm shadow-blue-600/20 hover:bg-blue-700">
      Support Impact
    </a>
  </nav>
</header>
