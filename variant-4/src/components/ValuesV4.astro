---
const values = [
  {
    title: 'Transparency',
    marker: '01',
    text: 'Clear reporting practices, practical metrics, and accountable communication across programs.',
  },
  {
    title: 'Community',
    marker: '02',
    text: 'Local partnerships and volunteer networks that keep support close to children and families.',
  },
  {
    title: 'Long-Term Impact',
    marker: '03',
    text: 'Program models designed for continuity, measured progress, and durable educational outcomes.',
  },
];
---

<section class="bg-white">
  <div class="mx-auto max-w-7xl px-5 py-16 sm:px-6 lg:px-8">
    <div class="mb-10 max-w-3xl">
      <p class="text-sm font-semibold uppercase tracking-[0.18em] text-[#F59E0B]">Operating Values</p>
      <h2 class="mt-3 text-3xl font-bold text-[#111827] sm:text-4xl">How The Foundation Works</h2>
    </div>

    <div class="grid gap-6 lg:grid-cols-3">
      {values.map((value) => (
        <article class="rounded-lg border border-gray-200 bg-[#FFFFFF] p-6 shadow-sm">
          <div class="mb-8 flex h-12 w-12 items-center justify-center rounded bg-[#F9FAFB] text-sm font-bold text-[#2563EB]">
            {value.marker}
          </div>
          <h3 class="text-xl font-bold text-[#111827]">{value.title}</h3>
          <p class="mt-4 text-sm leading-6 text-gray-600">{value.text}</p>
        </article>
      ))}
    </div>
  </div>
</section>
