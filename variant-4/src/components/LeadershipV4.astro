---
import founderOne from '../assets/founder-1.png';
import founderTwo from '../assets/founder-2.png';
import founderThree from '../assets/founder-3.png';

const leaders = [
  {
    name: 'Aravind Kumar',
    role: 'Founder',
    image: founderOne,
    description: 'Sets foundation strategy, governance priorities, and long-term education impact goals.',
  },
  {
    name: 'Suresh Narayanan',
    role: 'Co-Founder',
    image: founderTwo,
    description: 'Leads institutional partnerships, resource planning, and community operating alignment.',
  },
  {
    name: 'Karthik Raman',
    role: 'Program Director',
    image: founderThree,
    description: 'Oversees program delivery, volunteer coordination, and outcome tracking across regions.',
  },
];
---

<section class="border-y border-gray-200 bg-[#F9FAFB]">
  <div class="mx-auto max-w-7xl px-5 py-16 sm:px-6 lg:px-8">
    <div class="mb-10 flex flex-col justify-between gap-5 md:flex-row md:items-end">
      <div>
        <p class="text-sm font-semibold uppercase tracking-[0.18em] text-[#0F766E]">Governance & Delivery</p>
        <h2 class="mt-3 text-3xl font-bold text-[#111827] sm:text-4xl">Leadership</h2>
      </div>
      <p class="max-w-xl text-base leading-7 text-gray-600">
        Leadership responsibilities are presented around strategy, partnerships, and program execution.
      </p>
    </div>

    <div class="grid gap-6 lg:grid-cols-3">
      {leaders.map((leader) => (
        <article class="rounded-lg border border-gray-200 bg-white p-6 shadow-sm">
          <div class="flex items-center gap-5">
            <img src={leader.image.src} alt={leader.name} class="h-20 w-20 rounded-md object-cover" />
            <div>
              <h3 class="text-xl font-bold text-[#111827]">{leader.name}</h3>
              <p class="mt-1 text-sm font-semibold text-[#2563EB]">{leader.role}</p>
            </div>
          </div>
          <p class="mt-6 border-t border-gray-200 pt-5 text-sm leading-6 text-gray-600">{leader.description}</p>
        </article>
      ))}
    </div>
  </div>
</section>
