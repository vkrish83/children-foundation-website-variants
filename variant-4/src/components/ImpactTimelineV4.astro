---
const milestones = [
  { year: '2018', title: 'Foundation established' },
  { year: '2020', title: 'Expanded community programs' },
  { year: '2022', title: 'Volunteer network growth' },
  { year: '2024', title: 'Regional outreach expansion' },
  { year: '2026', title: '500+ children supported' },
];
---

<section class="bg-white">
  <div class="mx-auto max-w-7xl px-5 py-16 sm:px-6 lg:px-8">
    <div class="mb-12 max-w-3xl">
      <p class="text-sm font-semibold uppercase tracking-[0.18em] text-[#2563EB]">Development Timeline</p>
      <h2 class="mt-3 text-3xl font-bold text-[#111827] sm:text-4xl">Impact Milestones</h2>
      <p class="mt-4 text-base leading-7 text-gray-600">
        Key operating milestones presented in annual-report format for clarity and continuity.
      </p>
    </div>

    <div class="grid gap-5 lg:grid-cols-5">
      {milestones.map((milestone, index) => (
        <article class="relative rounded-lg border border-gray-200 bg-[#F9FAFB] p-6">
          <div class="mb-5 flex items-center justify-between">
            <span class="text-3xl font-bold text-[#111827]">{milestone.year}</span>
            <span class="flex h-8 w-8 items-center justify-center rounded-full bg-[#2563EB] text-xs font-bold text-white">
              {index + 1}
            </span>
          </div>
          <div class="h-1 w-12 rounded-full bg-[#F59E0B]"></div>
          <h3 class="mt-5 text-base font-bold leading-6 text-[#111827]">{milestone.title}</h3>
        </article>
      ))}
    </div>
  </div>
</section>
