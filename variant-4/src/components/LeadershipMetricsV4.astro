---
const metrics = [
  { value: '5', label: 'Operating Areas', color: 'text-[#2563EB]' },
  { value: '8', label: 'Communities', color: 'text-[#0F766E]' },
  { value: '12', label: 'Programs', color: 'text-[#2563EB]' },
  { value: '86%', label: 'Continuity', color: 'text-[#F59E0B]' },
];
---

<section id="impact" class="bg-[#F9FAFB]">
  <div class="mx-auto max-w-7xl px-5 py-16 sm:px-6 lg:px-8">
    <div class="rounded-lg border border-gray-200 bg-white shadow-sm">
      <div class="grid gap-6 border-b border-gray-200 p-6 lg:grid-cols-[0.85fr_1.15fr] lg:items-end lg:p-8">
        <div>
          <p class="text-sm font-semibold uppercase tracking-[0.18em] text-[#F59E0B]">Leadership Metrics</p>
          <h2 class="mt-3 text-3xl font-bold text-[#111827] sm:text-4xl">Governance Dashboard</h2>
        </div>
        <p class="max-w-2xl text-base leading-7 text-gray-600 lg:justify-self-end">
          Current operating indicators provide a compact view of leadership scope and program continuity.
        </p>
      </div>

      <div class="grid gap-0 sm:grid-cols-2 lg:grid-cols-4">
        {metrics.map((metric, index) => (
          <div class={`p-6 lg:p-8 ${index < metrics.length - 1 ? 'border-b border-gray-200 sm:border-r lg:border-b-0' : ''}`}>
            <p class={`text-4xl font-bold ${metric.color}`}>{metric.value}</p>
            <p class="mt-3 text-sm font-semibold uppercase tracking-[0.14em] text-gray-500">{metric.label}</p>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
